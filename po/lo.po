#: schemas/org.gnome.desktop.a11y.applications.gschema.xml.in:6
msgid "On-screen keyboard"
msgstr "ຄີບອດເທິງໜ້າຈໍ"

#: schemas/org.gnome.desktop.a11y.applications.gschema.xml.in:7
msgid "Whether the on-screen keyboard is turned on."
msgstr "ສະແດງວ່າຄີບອດເທິງໜ້າຈໍເປີດຢູ່ບໍ່."

#: schemas/org.gnome.desktop.a11y.applications.gschema.xml.in:11
msgid "Screen magnifier"
msgstr "ແວ່ນຂະຫຍາຍໜ້າຈໍ"

#: schemas/org.gnome.desktop.a11y.applications.gschema.xml.in:12
msgid "Whether the screen magnifier is turned on."
msgstr "ສະແດງວ່າແວ່ນຂະຫຍາຍໜ້າຈໍເປີດຢູ່ບໍ່."

#: schemas/org.gnome.desktop.a11y.applications.gschema.xml.in:16
msgid "Screen reader"
msgstr "ໂຕອ່ານໜ້າຈໍ"

#: schemas/org.gnome.desktop.a11y.applications.gschema.xml.in:17
msgid "Whether the screen reader is turned on."
msgstr "ສະແດງວ່າໂຕອ່ານໜ້າຈໍເປີດຢູ່ບໍ່."

#: schemas/org.gnome.desktop.a11y.gschema.xml.in:6
msgid "Always show the Universal Access status icon"
msgstr "ສະແດງໄອຄອນສະຖານະການຊ່ວຍເຫຼືອການເຂົ້າເຖິງຕະຫຼອດເວລາ"

#: schemas/org.gnome.desktop.a11y.gschema.xml.in:7
msgid ""
"This key overrides the automatic hiding of the Universal Access status icon "
"when no accessibility features are enabled."
msgstr "ການຕັ້ງຄ່ານີ້ຈະຍົກເລີກການເຊື່ອງໄອຄອນສະຖານະການຊ່ວຍເຫຼືອການເຂົ້າເຖິງອັດຕະໂນມັດ ເມື່ອບໍ່ມີຄຸນສົມບັດການຊ່ວຍເຫຼືອການເຂົ້າເຖິງໃດໆຖືກເປີດໃຊ້ງານ."

#: schemas/org.gnome.desktop.a11y.gschema.xml.in:14
msgid "Always show the text caret"
msgstr "ສະແດງເຄີເຊີຂໍ້ຄວາມຕະຫຼອດເວລາ"

#: schemas/org.gnome.desktop.a11y.gschema.xml.in:15
msgid ""
"This key overrides the hiding of the text caret in noneditable text in "
"applications."
msgstr "ການຕັ້ງຄ່ານີ້ຈະຍົກເລີກການເຊື່ອງເຄີເຊີຂໍ້ຄວາມໃນສ່ວນຂອງຂໍ້ຄວາມທີ່ບໍ່ສາມາດແກ້ໄຂໄດ້ໃນແອັບພລິເຄຊັນ."

#: schemas/org.gnome.desktop.a11y.interface.gschema.xml.in:6
msgid "High contrast"
msgstr "ຄວາມຄົມຊັດສູງ"

#: schemas/org.gnome.desktop.a11y.interface.gschema.xml.in:7
msgid "Whether to use the high contrast style."
msgstr "ສະແດງວ່າຈະໃຊ້ຮູບແບບຄວາມຄົມຊັດສູງບໍ່."

#: schemas/org.gnome.desktop.a11y.interface.gschema.xml.in:13
msgid "Show status shapes"
msgstr "ສະແດງຮູບຮ່າງສະຖານະ"

#: schemas/org.gnome.desktop.a11y.interface.gschema.xml.in:14
msgid ""
"Whether to use shapes to indicate status in addition or instead of color."
msgstr "ສະແດງວ່າຈະໃຊ້ຮູບຮ່າງເພື່ອບົ່ງບອກສະຖານະເພີ່ມເຕີມ ຫຼື ແທນທີ່ການໃຊ້ສີບໍ່."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:6
msgid "Enable accessibility keyboard shortcuts"
msgstr "ເປີດໃຊ້ຄີລັດຄີບອດເພື່ອການຊ່ວຍເຫຼືອການເຂົ້າເຖິງ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:10
msgid "Beep when a keyboard accessibility feature changes"
msgstr "ສົ່ງສຽງເຕືອນເມື່ອຄຸນສົມບັດການຊ່ວຍເຫຼືອການເຂົ້າເຖິງຂອງຄີບອດປ່ຽນແປງ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:11
msgid ""
"Whether to beep when a keyboard accessibility feature is enabled or disabled."
msgstr "ສະແດງວ່າຈະສົ່ງສຽງເຕືອນບໍ່ ເມື່ອຄຸນສົມບັດການຊ່ວຍເຫຼືອການເຂົ້າເຖິງຂອງຄີບອດຖືກເປີດ ຫຼື ປິດໃຊ້ງານ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:15
msgid "Disable keyboard accessibility after a timeout"
msgstr "ປິດໃຊ້ການຊ່ວຍເຫຼືອການເຂົ້າເຖິງຂອງຄີບອດຫຼັງຈາກໝົດເວລາ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:16
msgid ""
"Whether to disable keyboard accessibility after a timeout, useful for shared "
"machines."
msgstr "ສະແດງວ່າຈະປິດໃຊ້ການຊ່ວຍເຫຼືອການເຂົ້າເຖິງຂອງຄີບອດຫຼັງຈາກໝົດເວລາບໍ່, ເຊິ່ງມີປະໂຫຍດສຳລັບຄອມພິວເຕີທີ່ໃຊ້ຮ່ວມກັນ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:20
msgid "Duration of the disabling timeout"
msgstr "ໄລຍະເວລາຂອງການປິດໃຊ້ງານເມື່ອໝົດເວລາ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:21
msgid "Duration of the timeout before disabling the keyboard accessibility."
msgstr "ໄລຍະເວລາ ກ່ອນທີ່ຈະປິດໃຊ້ການຊ່ວຍເຫຼືອການເຂົ້າເຖິງຂອງຄີບອດ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:25
msgid "Enable “Bounce Keys”"
msgstr "ເປີດໃຊ້ “ປຸ່ມກັນການກົດຊ້ຳ”"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:26
msgid "Whether the “Bounce Keys” keyboard accessibility feature is turned on."
msgstr "ສະແດງວ່າຄຸນສົມບັດການຊ່ວຍເຫຼືອການເຂົ້າເຖິງຄີບອດ “ປຸ່ມກັນການກົດຊ້ຳ” ເປີດຢູ່ບໍ່."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:30
#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:65
msgid "Minimum interval in milliseconds"
msgstr "ໄລຍະຫ່າງຕ່ຳສຸດເປັນມິນລິວິນາທີ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:31
msgid "Ignore multiple presses of the same key within this many milliseconds."
msgstr "ບໍ່ສົນໃຈການກົດປຸ່ມດຽວກັນຫຼາຍຄັ້ງພາຍໃນໄລຍະເວລາມິນລິວິນາທີນີ້."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:35
#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:80
msgid "Beep when a key is rejected"
msgstr "ສົ່ງສຽງເຕືອນເມື່ອປຸ່ມຖືກປະຕິເສດ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:36
#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:81
msgid "Whether to beep when a key is rejected."
msgstr "ສະແດງວ່າຈະສົ່ງສຽງເຕືອນບໍ່ ເມື່ອປຸ່ມຖືກປະຕິເສດ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:40
msgid "Enable “Mouse Keys”"
msgstr "ເປີດໃຊ້ “ປຸ່ມເມົ້າສ໌”"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:41
msgid "Whether the “Mouse Keys” accessibility feature is turned on."
msgstr "ສະແດງວ່າຄຸນສົມບັດການຊ່ວຍເຫຼືອການເຂົ້າເຖິງ “ປຸ່ມເມົ້າສ໌” ເປີດຢູ່ບໍ່."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:45
msgid "Pixels per seconds"
msgstr "ພິກເຊລຕໍ່ວິນາທີ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:46
msgid "How many pixels per second to move at the maximum speed."
msgstr "ຈຳນວນພິກເຊລຕໍ່ວິນາທີທີ່ຈະເຄື່ອນທີ່ດ້ວຍຄວາມໄວສູງສຸດ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:50
msgid "How long to accelerate in milliseconds"
msgstr "ໄລຍະເວລາໃນການເລັ່ງຄວາມໄວເປັນມິນລິວິນາທີ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:51
msgid "How many milliseconds it takes to go from 0 to maximum speed."
msgstr "ຈຳນວນມິນລິວິນາທີທີ່ໃຊ້ໃນການປ່ຽນຈາກ 0 ໄປຫາຄວາມໄວສູງສຸດ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:55
msgid "Initial delay in milliseconds"
msgstr "ການໜ່ວງເວລາເລີ່ມຕົ້ນເປັນມິນລິວິນາທີ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:56
msgid ""
"How many milliseconds to wait before mouse movement keys start to operate."
msgstr "ຈຳນວນມິນລິວິນາທີທີ່ຕ້ອງລໍຖ້າກ່ອນທີ່ປຸ່ມເຄື່ອນໄຫວຂອງເມົ້າສ໌ຈະເລີ່ມເຮັດວຽກ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:60
msgid "Enable “Slow Keys”"
msgstr "ເປີດໃຊ້ “ປຸ່ມຊ້າ”"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:61
msgid "Whether the “Slow Keys” accessibility feature is turned on."
msgstr "ສະແດງວ່າຄຸນສົມບັດການຊ່ວຍເຫຼືອການເຂົ້າເຖິງ “ປຸ່ມຊ້າ” ເປີດຢູ່ບໍ່."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:66
msgid ""
"Do not accept a key as being pressed unless held for this many milliseconds."
msgstr "ຈະບໍ່ຮັບຮູ້ການກົດປຸ່ມ ຈົນກວ່າຈະກົດຄ້າງໄວ້ເປັນເວລາຫຼາຍມິນລິວິນາທີນີ້."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:70
msgid "Beep when a key is first pressed"
msgstr "ສົ່ງສຽງເຕືອນເມື່ອກົດປຸ່ມຄັ້ງທຳອິດ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:71
msgid "Whether to beep when a key is first pressed."
msgstr "ສະແດງວ່າຈະສົ່ງສຽງເຕືອນບໍ່ ເມື່ອກົດປຸ່ມຄັ້ງທຳອິດ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:75
msgid "Beep when a key is accepted"
msgstr "ສົ່ງສຽງເຕືອນເມື່ອປຸ່ມຖືກຍອມຮັບ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:76
msgid "Whether to beep when a key is accepted."
msgstr "ສະແດງວ່າຈະສົ່ງສຽງເຕືອນບໍ່ ເມື່ອປຸ່ມຖືກຍອມຮັບ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:85
msgid "Enable sticky keys"
msgstr "ເປີດໃຊ້ປຸ່ມຄ້າງ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:86
msgid "Whether the sticky keys accessibility feature is turned on."
msgstr "ສະແດງວ່າຄຸນສົມບັດການຊ່ວຍເຫຼືອການເຂົ້າເຖິງປຸ່ມຄ້າງເປີດຢູ່ບໍ່."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:90
msgid "Disable when two keys are pressed at the same time"
msgstr "ປິດໃຊ້ງານເມື່ອກົດສອງປຸ່ມພ້ອມກັນ"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:91
msgid ""
"Whether to disable sticky keys if two keys are pressed at the same time."
msgstr "ສະແດງວ່າຈະປິດໃຊ້ງານປຸ່ມຄ້າງບໍ່ ຖ້າມີການກົດສອງປຸ່ມພ້ອມກັນ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:95
msgid "Beep when a modifier is pressed."
msgstr "ສົ່ງສຽງເຕືອນເມື່ອກົດປຸ່ມໂມດິໄຟເອີ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:96
msgid "Whether to beep when a modifier key is pressed."
msgstr "ສະແດງວ່າຈະສົ່ງສຽງເຕືອນບໍ່ ເມື່ອກົດປຸ່ມໂມດິໄຟເອີ."

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:100
msgid "Enable “Toggle Keys”"
msgstr "ເປີດໃຊ້ “ປຸ່ມສະຫຼັບ”"

#: schemas/org.gnome.desktop.a11y.keyboard.gschema.xml.in:101
msgid "Whether the “Toggle Keys” accessibility feature is turned on."
msgstr "ສະແດງວ່າຄຸນສົມບັດການຊ່ວຍເຫຼືອການເຂົ້າເຖິງ “ປຸ່ມສະຫຼັບ” ເປີດຢູ່ບໍ່."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:8
msgid "Mouse Tracking Mode"
msgstr "ໂໝດການຕິດຕາມເມົ້າສ໌"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:9
msgid ""
"Determines the position of the magnified mouse image within the magnified "
"view and how it reacts to system mouse movement. The values are • none: no "
"mouse tracking; • centered: the mouse image is displayed at the center of "
"the zoom region (which also represents the point under the system mouse) and "
"the magnified contents are scrolled as the system mouse moves; • "
"proportional: the position of the magnified mouse in the zoom region is "
"proportionally the same as the position of the system mouse on screen; • "
"push: when the magnified mouse intersects a boundary of the zoom region, the "
"contents are scrolled into view."
msgstr "ກຳນົດຕຳແໜ່ງຂອງຮູບພາບເມົ້າສ໌ທີ່ຂະຫຍາຍພາຍໃນມຸມມອງທີ່ຂະຫຍາຍ ແລະ ວິທີທີ່ມັນຕອບສະໜອງຕໍ່ການເຄື່ອນໄຫວຂອງເມົ້າສ໌ລະບົບ. ຄ່າຕ່າງໆແມ່ນ • none: ບໍ່ມີການຕິດຕາມເມົ້າສ໌; • centered: ຮູບພາບເມົ້າສ໌ຈະຖືກສະແດງຢູ່ໃຈກາງຂອງພື້ນທີ່ຊູມ (ເຊິ່ງເປັນຕົວແທນຂອງຈຸດທີ່ຢູ່ໃຕ້ເມົ້າສ໌ຂອງລະບົບ) ແລະ ເນື້ອຫາທີ່ຂະຫຍາຍຈະເລື່ອນໄປຕາມການເຄື່ອນທີ່ຂອງເມົ້າສ໌ລະບົບ; • proportional: ຕຳແໜ່ງຂອງເມົ້າສ໌ທີ່ຂະຫຍາຍໃນພື້ນທີ່ຊູມຈະມີສັດສ່ວນເທົ່າກັນກັບຕຳແໜ່ງຂອງເມົ້າສ໌ລະບົບເທິງໜ້າຈໍ; • push: ເມື່ອເມົ້າສ໌ທີ່ຂະຫຍາຍຕັດຜ່ານຂອບເຂດຂອງພື້ນທີ່ຊູມ, ເນື້ອຫາຈະຖືກເລື່ອນເຂົ້າມາໃນມຸມມອງ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:26
msgid "Focus Tracking Mode"
msgstr "ໂໝດການຕິດຕາມຈຸດໂຟກັສ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:27
msgid ""
"Determines the position of the focused widget within magnified view. The "
"values are: • none: no focus tracking • centered: the focused image is "
"displayed at the center of the zoom region (which also represents the point "
"under the system focus) and the magnified contents are scrolled as the "
"system focus moves • proportional: the position of the magnified focus in "
"the zoom region is proportionally the same as the position of the system "
"focus on screen • push: when the magnified focus intersects a boundary of "
"the zoom region, the contents are scrolled into view"
msgstr "ກຳນົດຕຳແໜ່ງຂອງວິດເຈັດທີ່ຖືກໂຟກັສພາຍໃນມຸມມອງທີ່ຂະຫຍາຍ. ຄ່າຕ່າງໆແມ່ນ: • none: ບໍ່ມີການຕິດຕາມຈຸດໂຟກັສ • centered: ຮູບພາບທີ່ຖືກໂຟກັສຈະຖືກສະແດງຢູ່ໃຈກາງຂອງພື້ນທີ່ຊູມ (ເຊິ່ງເປັນຕົວແທນຂອງຈຸດທີ່ຢູ່ໃຕ້ຈຸດໂຟກັສຂອງລະບົບ) ແລະ ເນື້ອຫາທີ່ຂະຫຍາຍຈະເລື່ອນໄປຕາມການເຄື່ອນທີ່ຂອງຈຸດໂຟກັສລະບົບ • proportional: ຕຳແໜ່ງຂອງຈຸດໂຟກັສທີ່ຂະຫຍາຍໃນພື້ນທີ່ຊູມຈະມີສັດສ່ວນເທົ່າກັນກັບຕຳແໜ່ງຂອງຈຸດໂຟກັສລະບົບເທິງໜ້າຈໍ • push: ເມື່ອຈຸດໂຟກັສທີ່ຂະຫຍາຍຕັດຜ່ານຂອບເຂດຂອງພື້ນທີ່ຊູມ, ເນື້ອຫາຈະຖືກເລື່ອນເຂົ້າມາໃນມຸມມອງ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:46
msgid "Caret Tracking Mode"
msgstr "ໂໝດການຕິດຕາມເຄີເຊີ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:47
msgid ""
"Determines the position of the caret within magnified view. The values are: "
"• none: no caret tracking • centered: the image of the caret is displayed at "
"the center of the zoom region (which also represents the point under the "
"system caret) and the magnified contents are scrolled as the system caret "
"moves • proportional: the position of the magnified caret in the zoom region "
"is proportionally the same as the position of the system caret on screen • "
"push: when the magnified caret intersects a boundary of the zoom region, the "
"contents are scrolled into view"
msgstr "ກຳນົດຕຳແໜ່ງຂອງເຄີເຊີພາຍໃນມຸມມອງທີ່ຂະຫຍາຍ. ຄ່າຕ່າງໆແມ່ນ: • none: ບໍ່ມີການຕິດຕາມເຄີເຊີ • centered: ຮູບພາບຂອງເຄີເຊີຈະຖືກສະແດງຢູ່ໃຈກາງຂອງພື້ນທີ່ຊູມ (ເຊິ່ງເປັນຕົວແທນຂອງຈຸດທີ່ຢູ່ໃຕ້ເຄີເຊີຂອງລະບົບ) ແລະ ເນື້ອຫາທີ່ຂະຫຍາຍຈະເລື່ອນໄປຕາມການເຄື່ອນທີ່ຂອງເຄີເຊີລະບົບ • proportional: ຕຳແໜ່ງຂອງເຄີເຊີທີ່ຂະຫຍາຍໃນພື້ນທີ່ຊູມຈະມີສັດສ່ວນເທົ່າກັນກັບຕຳແໜ່ງຂອງເຄີເຊີລະບົບເທິງໜ້າຈໍ • push: ເມື່ອເຄີເຊີທີ່ຂະຫຍາຍຕັດຜ່ານຂອບເຂດຂອງພື້ນທີ່ຊູມ, ເນື້ອຫາຈະຖືກເລື່ອນເຂົ້າມາໃນມຸມມອງ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:64
msgid "Screen position"
msgstr "ຕຳແໜ່ງໜ້າຈໍ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:65
msgid ""
"The magnified view either fills the entire screen, or occupies the top-half, "
"bottom-half, left-half, or right-half of the screen."
msgstr "ມຸມມອງທີ່ຂະຫຍາຍຈະເຕັມໜ້າຈໍທັງໝົດ, ຫຼື ຄອບຄອງເຄິ່ງເທິງ, ເຄິ່ງລຸ່ມ, ເຄິ່ງຊ້າຍ, ຫຼື ເຄິ່ງຂວາຂອງໜ້າຈໍ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:73
msgid "Magnification factor"
msgstr "ລະດັບການຂະຫຍາຍ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:74
msgid ""
"The power of the magnification. A value of 1.0 means no magnification. A "
"value of 2.0 doubles the size."
msgstr "ກຳລັງຂອງການຂະຫຍາຍ. ຄ່າ 1.0 ໝາຍເຖິງບໍ່ມີການຂະຫຍາຍ. ຄ່າ 2.0 ຈະເພີ່ມຂະໜາດເປັນສອງເທົ່າ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:81
msgid "Enable lens mode"
msgstr "ເປີດໃຊ້ໂໝດເລນ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:82
msgid ""
"Whether the magnified view should be centered over the location of the "
"system mouse and move with it."
msgstr "ສະແດງວ່າມຸມມອງທີ່ຂະຫຍາຍຄວນຢູ່ໃຈກາງເໜືອຕຳແໜ່ງຂອງເມົ້າສ໌ລະບົບ ແລະ ເຄື່ອນທີ່ໄປພ້ອມກັບມັນບໍ່."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:89
msgid "Scroll magnified contents beyond the edges of the desktop"
msgstr "ເລື່ອນເນື້ອຫາທີ່ຂະຫຍາຍເກີນຂອບຂອງໜ້າຈໍ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:92
msgid ""
"For centered mouse tracking, when the system pointer is at or near the edge "
"of the screen, the magnified contents continue to scroll such that the "
"screen edge moves into the magnified view."
msgstr "ສຳລັບການຕິດຕາມເມົ້າສ໌ແບບໃຈກາງ, ເມື່ອຕົວຊີ້ຂອງລະບົບຢູ່ທີ່ ຫຼື ໃກ້ຂອບຂອງໜ້າຈໍ, ເນື້ອຫາທີ່ຂະຫຍາຍຈະສືບຕໍ່ເລື່ອນ ເພື່ອໃຫ້ຂອບຂອງໜ້າຈໍເຄື່ອນເຂົ້າມາໃນມຸມມອງທີ່ຂະຫຍາຍ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:102
msgid "Show or hide crosshairs"
msgstr "ສະແດງ ຫຼື ເຊື່ອງເສັ້ນຕັດ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:103
msgid ""
"Enables/disables display of crosshairs centered on the magnified mouse "
"sprite."
msgstr "ເປີດ/ປິດການສະແດງຜົນຂອງເສັ້ນຕັດທີ່ຢູ່ໃຈກາງເທິງຮູບເມົ້າສ໌ທີ່ຂະຫຍາຍ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:110
msgid "Thickness of the crosshairs in pixels"
msgstr "ຄວາມໜາຂອງເສັ້ນຕັດເປັນພິກເຊລ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:111
msgid ""
"Width in pixels of the vertical and horizontal lines that make up the "
"crosshairs."
msgstr "ຄວາມກວ້າງເປັນພິກເຊລຂອງເສັ້ນຕັ້ງ ແລະ ເສັ້ນນອນທີ່ປະກອບເປັນເສັ້ນຕັດ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:117
msgid "Color of the crosshairs"
msgstr "ສີຂອງເສັ້ນຕັດ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:118
msgid ""
"The color of the the vertical and horizontal lines that make up the "
"crosshairs."
msgstr "ສີຂອງເສັ້ນຕັ້ງ ແລະ ເສັ້ນນອນທີ່ປະກອບເປັນເສັ້ນຕັດ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:126
msgid "Opacity of the crosshairs"
msgstr "ຄວາມໂປ່ງໃສຂອງເສັ້ນຕັດ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:127
msgid ""
"Determines the transparency of the crosshairs, from fully opaque to fully "
"transparent."
msgstr "ກຳນົດຄວາມໂປ່ງໃສຂອງເສັ້ນຕັດ, ຈາກທຶບແສງເຕັມທີ່ໄປຫາໂປ່ງໃສເຕັມທີ່."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:135
msgid "Length of the crosshairs in pixels"
msgstr "ຄວາມຍາວຂອງເສັ້ນຕັດເປັນພິກເຊລ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:136
msgid ""
"Determines the length in pixels of the vertical and horizontal lines that "
"make up the crosshairs."
msgstr "ກຳນົດຄວາມຍາວເປັນພິກເຊລຂອງເສັ້ນຕັ້ງ ແລະ ເສັ້ນນອນທີ່ປະກອບເປັນເສັ້ນຕັດ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:143
msgid "Clip the crosshairs at the center"
msgstr "ຕັດເສັ້ນຕັດຢູ່ທີ່ໃຈກາງ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:144
msgid ""
"Determines whether the crosshairs intersect the magnified mouse sprite, or "
"are clipped such that the ends of the horizontal and vertical lines surround "
"the mouse image."
msgstr "ກຳນົດວ່າເສັ້ນຕັດຈະຕັດຜ່ານຮູບເມົ້າສ໌ທີ່ຂະຫຍາຍ, ຫຼື ຈະຖືກຕັດອອກເພື່ອໃຫ້ປາຍຂອງເສັ້ນນອນ ແລະ ເສັ້ນຕັ້ງອ້ອມຮອບຮູບເມົ້າສ໌."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:152
msgid "Inverse lightness"
msgstr "ປີ້ນຄວາມສະຫວ່າງ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:153
msgid ""
"Determines whether the lightness values are inverted: darker colors become "
"lighter and vice versa, and white and black are interchanged."
msgstr "ກຳນົດວ່າຄ່າຄວາມສະຫວ່າງຈະຖືກປີ້ນກັນບໍ່: ສີເຂັ້ມຈະກາຍເປັນສີອ່ອນ ແລະ ກົງກັນຂ້າມ, ແລະ ສີຂາວ ແລະ ສີດຳຈະຖືກສັບປ່ຽນກັນ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:161
msgid "Color Saturation"
msgstr "ຄວາມອີ່ມຕົວຂອງສີ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:162
msgid ""
"Represents a change to the color saturation, from 0.0 (grayscale) to 1.0 "
"(full color)."
msgstr "ສະແດງເຖິງການປ່ຽນແປງຂອງຄວາມອີ່ມຕົວຂອງສີ, ຈາກ 0.0 (ສີເທົາ) ໄປຫາ 1.0 (ສີເຕັມ)."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:170
msgid "Change brightness of red"
msgstr "ປ່ຽນຄວາມສະຫວ່າງຂອງສີແດງ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:171
msgid ""
"Represents a change to the default brightness of the red component. Zero "
"indicates no change, values less than zero indicate a decrease, and values "
"greater than zero indicate an increase."
msgstr "ສະແດງເຖິງການປ່ຽນແປງຂອງຄວາມສະຫວ່າງເລີ່ມຕົ້ນຂອງອົງປະກອບສີແດງ. ສູນ ໝາຍເຖິງບໍ່ມີການປ່ຽນແປງ, ຄ່າທີ່ນ້ອຍກວ່າສູນໝາຍເຖິງການຫຼຸດລົງ, ແລະ ຄ່າທີ່ໃຫຍ່ກວ່າສູນໝາຍເຖິງການເພີ່ມຂຶ້ນ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:180
msgid "Change brightness of green"
msgstr "ປ່ຽນຄວາມສະຫວ່າງຂອງສີຂຽວ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:181
msgid ""
"Represents a change to the default brightness for the green component. Zero "
"indicates no change, values less than zero indicate a decrease, and values "
"greater than zero indicate an increase."
msgstr "ສະແດງເຖິງການປ່ຽນແປງຂອງຄວາມສະຫວ່າງເລີ່ມຕົ້ນຂອງອົງປະກອບສີຂຽວ. ສູນ ໝາຍເຖິງບໍ່ມີການປ່ຽນແປງ, ຄ່າທີ່ນ້ອຍກວ່າສູນໝາຍເຖິງການຫຼຸດລົງ, ແລະ ຄ່າທີ່ໃຫຍ່ກວ່າສູນໝາຍເຖິງການເພີ່ມຂຶ້ນ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:190
msgid "Change brightness of blue"
msgstr "ປ່ຽນຄວາມສະຫວ່າງຂອງສີຟ້າ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:191
msgid ""
"Represents a change to the default brightness for the blue component. Zero "
"indicates no change, values less than zero indicate a decrease, and values "
"greater than zero indicate an increase."
msgstr "ສະແດງເຖິງການປ່ຽນແປງຂອງຄວາມສະຫວ່າງເລີ່ມຕົ້ນຂອງອົງປະກອບສີຟ້າ. ສູນ ໝາຍເຖິງບໍ່ມີການປ່ຽນແປງ, ຄ່າທີ່ນ້ອຍກວ່າສູນໝາຍເຖິງການຫຼຸດລົງ, ແລະ ຄ່າທີ່ໃຫຍ່ກວ່າສູນໝາຍເຖິງການເພີ່ມຂຶ້ນ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:200
msgid "Change contrast of red"
msgstr "ປ່ຽນຄວາມຄົມຊັດຂອງສີແດງ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:201
msgid ""
"Represents a change to the default contrast of the red component. Zero "
"indicates no change in contrast, values less than zero indicate a decrease, "
"and values greater than zero indicate an increase."
msgstr "ສະແດງເຖິງການປ່ຽນແປງຂອງຄວາມຄົມຊັດເລີ່ມຕົ້ນຂອງອົງປະກອບສີແດງ. ສູນ ໝາຍເຖິງບໍ່ມີການປ່ຽນແປງ, ຄ່າທີ່ນ້ອຍກວ່າສູນໝາຍເຖິງການຫຼຸດລົງ, ແລະ ຄ່າທີ່ໃຫຍ່ກວ່າສູນໝາຍເຖິງການເພີ່ມຂຶ້ນ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:210
msgid "Change contrast of green"
msgstr "ປ່ຽນຄວາມຄົມຊັດຂອງສີຂຽວ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:211
msgid ""
"Represents a change to the default contrast of the green component. Zero "
"indicates no change in contrast, values less than zero indicate a decrease, "
"and values greater than zero indicate an increase."
msgstr "ສະແດງເຖິງການປ່ຽນແປງຂອງຄວາມຄົມຊັດເລີ່ມຕົ້ນຂອງອົງປະກອບສີຂຽວ. ສູນ ໝາຍເຖິງບໍ່ມີການປ່ຽນແປງ, ຄ່າທີ່ນ້ອຍກວ່າສູນໝາຍເຖິງການຫຼຸດລົງ, ແລະ ຄ່າທີ່ໃຫຍ່ກວ່າສູນໝາຍເຖິງການເພີ່ມຂຶ້ນ."

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:220
msgid "Change contrast of blue"
msgstr "ປ່ຽນຄວາມຄົມຊັດຂອງສີຟ້າ"

#: schemas/org.gnome.desktop.a11y.magnifier.gschema.xml.in:221
msgid ""
"Represents a change to the default contrast of the blue component. Zero "
"indicates no change in contrast, values less than zero indicate a decrease, "
"and values greater than zero indicate an increase."
msgstr "ສະແດງເຖິງການປ່ຽນແປງຂອງຄວາມຄົມຊັດເລີ່ມຕົ້ນຂອງອົງປະກອບສີຟ້າ. ສູນ ໝາຍເຖິງບໍ່ມີການປ່ຽນແປງ, ຄ່າທີ່ນ້ອຍກວ່າສູນໝາຍເຖິງການຫຼຸດລົງ, ແລະ ຄ່າທີ່ໃຫຍ່ກວ່າສູນໝາຍເຖິງການເພີ່ມຂຶ້ນ."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:6
msgid "Dwell click time"
msgstr "ເວລາຄລິກຄ້າງ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:7
msgid "Time in seconds before a click is triggered."
msgstr "ເວລາເປັນວິນາທີກ່ອນທີ່ການຄລິກຈະເກີດຂຶ້ນ."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:11
msgid "Movement threshold"
msgstr "ຂອບເຂດການເຄື່ອນໄຫວ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:12
msgid "Distance in pixels before movement will be recognized."
msgstr "ໄລຍະຫ່າງເປັນພິກເຊລກ່ອນທີ່ການເຄື່ອນໄຫວຈະຖືກຮັບຮູ້."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:16
msgid "Gesture single click"
msgstr "ທ່າທາງຄລິກຄັ້ງດຽວ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:17
msgid "Direction to perform a single click (“left”, “right”, “up”, “down”)."
msgstr "ທິດທາງເພື່ອທຳການຄລິກຄັ້ງດຽວ (“left”, “right”, “up”, “down”)."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:21
msgid "Gesture double click"
msgstr "ທ່າທາງຄລິກສອງຄັ້ງ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:22
msgid "Direction to perform a double click (“left”, “right”, “up”, “down”)."
msgstr "ທິດທາງເພື່ອທຳການຄລິກສອງຄັ້ງ (“left”, “right”, “up”, “down”)."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:26
msgid "Gesture drag click"
msgstr "ທ່າທາງຄລິກເພື່ອລາກ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:27
msgid "Direction to perform dragging (“left”, “right”, “up”, “down”)."
msgstr "ທິດທາງເພື່ອທຳການລາກ (“left”, “right”, “up”, “down”)."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:31
msgid "Gesture secondary click"
msgstr "ທ່າທາງຄລິກສຳຮອງ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:32
msgid "Direction to perform a secondary click (“left”, “right”, “up”, “down”)."
msgstr "ທິດທາງເພື່ອທຳການຄລິກສຳຮອງ (“left”, “right”, “up”, “down”)."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:36
msgid "Dwell click mode"
msgstr "ໂໝດຄລິກຄ້າງ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:37
msgid ""
"The active dwell click mode. Possible values are “window” and “gesture”."
msgstr "ໂໝດຄລິກຄ້າງທີ່ກຳລັງໃຊ້ງານຢູ່. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ “window” ແລະ “gesture”."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:41
msgid "Show click type window"
msgstr "ສະແດງໜ້າຕ່າງປະເພດການຄລິກ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:42
msgid "Show click type window."
msgstr "ສະແດງໜ້າຕ່າງປະເພດການຄລິກ."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:46
msgid "Enable dwell clicks"
msgstr "ເປີດໃຊ້ການຄລິກຄ້າງ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:47
msgid "Enable dwell clicks."
msgstr "ເປີດໃຊ້ການຄລິກຄ້າງ."

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:51
msgid "Secondary click enabled"
msgstr "ເປີດໃຊ້ການຄລິກສຳຮອງ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:52
msgid "Enable simulated secondary clicks"
msgstr "ເປີດໃຊ້ການຈຳລອງການຄລິກສຳຮອງ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:56
msgid "Secondary click time"
msgstr "ເວລາຄລິກສຳຮອງ"

#: schemas/org.gnome.desktop.a11y.mouse.gschema.xml.in:57
msgid "Time in seconds before a simulated secondary click is triggered."
msgstr "ເວລາເປັນວິນາທີກ່ອນທີ່ການຈຳລອງການຄລິກສຳຮອງຈະເກີດຂຶ້ນ."

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:6
msgid "Folder children"
msgstr "ລາຍການໃນໂຟລເດີ"

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:7
msgid ""
"List of relative settings paths at which app-folders are stored. Each folder "
"uses the org.gnome.desktop.app-folders.folder schema."
msgstr "ລາຍຊື່ເສັ້ນທາງການຕັ້ງຄ່າທີ່ກ່ຽວຂ້ອງບ່ອນທີ່ໂຟລເດີແອັບຖືກເກັບໄວ້. ແຕ່ລະໂຟລເດີໃຊ້ schema ຂອງ org.gnome.desktop.app-folders.folder."

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:15
msgid "Folder name"
msgstr "ຊື່ໂຟລເດີ"

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:16
msgid "The name of the application folder."
msgstr "ຊື່ຂອງໂຟລເດີແອັບພລິເຄຊັນ."

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:20
msgid "Translate the name"
msgstr "ແປຊື່"

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:21
msgid ""
"Whether the name key is a filename to be looked up in /usr/share/desktop-"
"directories."
msgstr "ສະແດງວ່າ name key ເປັນຊື່ໄຟລ໌ທີ່ຈະຖືກຄົ້ນຫາໃນ /usr/share/desktop-directories ບໍ່."

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:26
msgid "Applications"
msgstr "ແອັບພລິເຄຊັນ"

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:27
msgid ""
"The list of IDs of applications that are explicitly included in this folder."
msgstr "ລາຍຊື່ ID ຂອງແອັບພລິເຄຊັນທີ່ຖືກລວມຢູ່ໃນໂຟລເດີນີ້ຢ່າງຊັດເຈນ."

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:32
msgid "Categories"
msgstr "ໝວດໝູ່"

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:33
msgid ""
"A list of categories for which apps will be placed into this folder by "
"default, in addition to the apps that are listed in the apps key."
msgstr "ລາຍຊື່ໝວດໝູ່ທີ່ແອັບຈະຖືກຈັດໃສ່ໃນໂຟລເດີນີ້ໂດຍຄ່າເລີ່ມຕົ້ນ, ນອກເໜືອຈາກແອັບທີ່ລະບຸໄວ້ໃນ apps key."

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:39
msgid "Excluded applications"
msgstr "ແອັບພລິເຄຊັນທີ່ບໍ່ລວມ"

#: schemas/org.gnome.desktop.app-folders.gschema.xml.in:40
msgid ""
"A list of IDs of applications that are excluded from this folder. This can "
"be used to remove applications that would otherwise be included by category."
msgstr "ລາຍຊື່ ID ຂອງແອັບພລິເຄຊັນທີ່ຖືກຍົກເວັ້ນອອກຈາກໂຟລເດີນີ້. ສາມາດໃຊ້ເພື່ອລຶບແອັບພລິເຄຊັນທີ່ອາດຈະຖືກລວມເຂົ້າໂດຍໝວດໝູ່."

#: schemas/org.gnome.desktop.background.gschema.xml.in:6
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:97
msgid "Picture Options"
msgstr "ຕົວເລືອກຮູບພາບ"

#: schemas/org.gnome.desktop.background.gschema.xml.in:7
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:98
msgid ""
"Determines how the image set by wallpaper_filename is rendered. Possible "
"values are “none”, “wallpaper”, “centered”, “scaled”, “stretched”, “zoom”, "
"“spanned”."
msgstr "ກຳນົດວິທີການສະແດງຜົນຂອງຮູບພາບທີ່ຕັ້ງຄ່າໂດຍ wallpaper_filename. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ “none”, “wallpaper”, “centered”, “scaled”, “stretched”, “zoom”, “spanned”."

#: schemas/org.gnome.desktop.background.gschema.xml.in:15
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:106
msgid "Picture URI"
msgstr "URI ຮູບພາບ"

#: schemas/org.gnome.desktop.background.gschema.xml.in:16
#: schemas/org.gnome.desktop.background.gschema.xml.in:24
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:107
msgid ""
"URI to use for the background image. Note that the backend only supports "
"local (file://) URIs."
msgstr "URI ທີ່ຈະໃຊ້ສຳລັບຮູບພື້ນຫຼັງ. ໝາຍເຫດວ່າເບື້ອງຫຼັງຮອງຮັບສະເພາະ URI ພາຍໃນເຄື່ອງ (file://)."

#: schemas/org.gnome.desktop.background.gschema.xml.in:23
msgid "Picture URI (dark)"
msgstr "URI ຮູບພາບ (ໂໝດມືດ)"

#: schemas/org.gnome.desktop.background.gschema.xml.in:32
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:115
msgid "Picture Opacity"
msgstr "ຄວາມໂປ່ງໃສຂອງຮູບພາບ"

#: schemas/org.gnome.desktop.background.gschema.xml.in:33
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:116
msgid "Opacity with which to draw the background picture."
msgstr "ຄວາມໂປ່ງໃສທີ່ຈະໃຊ້ໃນການແຕ້ມຮູບພື້ນຫຼັງ."

#: schemas/org.gnome.desktop.background.gschema.xml.in:39
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:122
msgid "Primary Color"
msgstr "ສີຫຼັກ"

#: schemas/org.gnome.desktop.background.gschema.xml.in:40
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:123
msgid "Left or Top color when drawing gradients, or the solid color."
msgstr "ສີດ້ານຊ້າຍ ຫຼື ດ້ານເທິງເມື່ອແຕ້ມສີໄລ່ລະດັບ, ຫຼື ສີດຽວ."

#: schemas/org.gnome.desktop.background.gschema.xml.in:46
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:129
msgid "Secondary Color"
msgstr "ສີສຳຮອງ"

#: schemas/org.gnome.desktop.background.gschema.xml.in:47
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:130
msgid "Right or Bottom color when drawing gradients, not used for solid color."
msgstr "ສີດ້ານຂວາ ຫຼື ດ້ານລຸ່ມເມື່ອແຕ້ມສີໄລ່ລະດັບ, ບໍ່ໃຊ້ກັບສີດຽວ."

#: schemas/org.gnome.desktop.background.gschema.xml.in:53
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:136
msgid "Color Shading Type"
msgstr "ປະເພດການໄລ່ສີ"

#: schemas/org.gnome.desktop.background.gschema.xml.in:54
#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:137
msgid ""
"How to shade the background color. Possible values are “horizontal”, "
"“vertical”, and “solid”."
msgstr "ວິທີການໄລ່ສີພື້ນຫຼັງ. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ “horizontal”, “vertical”, ແລະ “solid”."

#: schemas/org.gnome.desktop.background.gschema.xml.in:61
msgid "Have file manager handle the desktop"
msgstr "ໃຫ້ໂຕຈັດການໄຟລ໌ຈັດການໜ້າຈໍເດັສທັອບ"

#: schemas/org.gnome.desktop.background.gschema.xml.in:62
msgid "If set to true, then file manager will draw the icons on the desktop."
msgstr "ຖ້າຕັ້ງເປັນ true, ໂຕຈັດການໄຟລ໌ຈະແຕ້ມໄອຄອນເທິງໜ້າຈໍເດັສທັອບ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:10
msgid "List of breaks that are currently enabled"
msgstr "ລາຍຊື່ການພັກຜ່ອນທີ່ກຳລັງເປີດໃຊ້ຢູ່"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:22
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:87
msgid "Time between breaks"
msgstr "ໄລຍະເວລາລະຫວ່າງການພັກຜ່ອນ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:23
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:88
msgid "The time between rest breaks, in seconds."
msgstr "ໄລຍະເວລາລະຫວ່າງການພັກຜ່ອນ, ເປັນວິນາທີ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:29
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:94
msgid "Duration of each break"
msgstr "ໄລຍະເວລາຂອງແຕ່ລະການພັກຜ່ອນ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:30
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:95
msgid "The duration of each rest break, in seconds."
msgstr "ໄລຍະເວລາຂອງແຕ່ລະການພັກຜ່ອນ, ເປັນວິນາທີ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:36
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:101
msgid "Amount to delay break if requested"
msgstr "ຈຳນວນເວລາທີ່ຈະເລື່ອນການພັກຜ່ອນອອກໄປຖ້າຖືກຮ້ອງຂໍ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:37
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:102
msgid ""
"The amount to delay taking the break by, if the user requests a delay, in "
"seconds."
msgstr "ຈຳນວນເວລາທີ່ຈະເລື່ອນການພັກຜ່ອນອອກໄປ, ຖ້າຜູ້ໃຊ້ຮ້ອງຂໍ, ເປັນວິນາທີ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:43
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:108
msgid "Fade screen during breaks"
msgstr "ເຮັດໃຫ້ໜ້າຈໍມືດລົງໃນລະຫວ່າງການພັກຜ່ອນ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:44
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:109
msgid "True to fade the screen during rest breaks."
msgstr "True ເພື່ອເຮັດໃຫ້ໜ້າຈໍມືດລົງໃນລະຫວ່າງການພັກຜ່ອນ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:49
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:114
msgid "Lock screen during breaks"
msgstr "ລັອກໜ້າຈໍໃນລະຫວ່າງການພັກຜ່ອນ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:50
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:115
msgid "True to lock the screen during rest breaks."
msgstr "True ເພື່ອລັອກໜ້າຈໍໃນລະຫວ່າງການພັກຜ່ອນ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:55
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:120
msgid "Play sound when a break finishes"
msgstr "ເປີດສຽງເມື່ອການພັກຜ່ອນສິ້ນສຸດລົງ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:56
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:121
msgid "True to play a sound when a break finishes."
msgstr "True ເພື່ອເປີດສຽງເມື່ອການພັກຜ່ອນສິ້ນສຸດລົງ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:61
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:79
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:126
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:144
msgid "Notify when a break is due"
msgstr "ແຈ້ງເຕືອນເມື່ອຮອດເວລາພັກຜ່ອນ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:62
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:127
msgid "True to emit a notification when a break is due to start."
msgstr "True ເພື່ອສົ່ງການແຈ້ງເຕືອນເມື່ອຮອດເວລາເລີ່ມການພັກຜ່ອນ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:67
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:132
msgid "Notify when a break is upcoming"
msgstr "ແຈ້ງເຕືອນເມື່ອໃກ້ຈະຮອດເວລາພັກຜ່ອນ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:68
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:133
msgid "True to emit a notification a few minutes before a break is due."
msgstr "True ເພື່ອສົ່ງການແຈ້ງເຕືອນສອງສາມນາທີກ່ອນທີ່ຈະຮອດເວລາພັກຜ່ອນ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:73
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:138
msgid "Notify when a break is overdue"
msgstr "ແຈ້ງເຕືອນເມື່ອການພັກຜ່ອນເກີນເວລາ"

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:74
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:139
msgid "True to emit a notification when a break is overdue."
msgstr "True ເພື່ອສົ່ງການແຈ້ງເຕືອນເມື່ອການພັກຜ່ອນເກີນເວລາ."

#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:80
#: schemas/org.gnome.desktop.break-reminders.gschema.xml.in:145
msgid "True to show a prominent countdown shortly before a break is due."
msgstr "True ເພື່ອສະແດງການນັບຖອຍຫຼັງທີ່ເຫັນໄດ້ຊັດເຈນ ກ່ອນທີ່ຈະຮອດເວລາພັກຜ່ອນບໍ່ດົນ."

#: schemas/org.gnome.desktop.calendar.gschema.xml.in:6
msgid "Show the week date in the calendar"
msgstr "ສະແດງວັນທີຂອງອາທິດໃນປະຕິທິນ"

#: schemas/org.gnome.desktop.calendar.gschema.xml.in:7
msgid "If true, display the ISO week date in the calendar."
msgstr "ຖ້າເປັນ true, ຈະສະແດງວັນທີຂອງອາທິດຕາມມາດຕະຖານ ISO ໃນປະຕິທິນ."

#: schemas/org.gnome.desktop.datetime.gschema.xml.in:6
msgid "Automatically update timezone"
msgstr "ອັບເດດເຂດເວລາອັດຕະໂນມັດ"

#: schemas/org.gnome.desktop.datetime.gschema.xml.in:7
msgid "Whether to automatically update the timezone using geolocation."
msgstr "ສະແດງວ່າຈະອັບເດດເຂດເວລາອັດຕະໂນມັດໂດຍໃຊ້ການລະບຸຕຳແໜ່ງພູມສາດບໍ່."

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:14
msgid "Default calendar"
msgstr "ປະຕິທິນເລີ່ມຕົ້ນ"

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:15
msgid ""
"Default calendar application DEPRECATED: This key is deprecated and ignored. "
"The preferred calendar application is the application handling the text/"
"calendar mime type."
msgstr "ແອັບພລິເຄຊັນປະຕິທິນເລີ່ມຕົ້ນ ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ. ແອັບພລິເຄຊັນປະຕິທິນທີ່ແນະນຳແມ່ນແອັບພລິເຄຊັນທີ່ຈັດການ mime type ປະເພດ text/calendar."

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:24
msgid "Calendar needs terminal"
msgstr "ປະຕິທິນຕ້ອງການເທີມິນໍ"

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:25
msgid ""
"Whether the default calendar application needs a terminal to run. "
"DEPRECATED: This key is deprecated and ignored. The preferred calendar "
"application is the application handling the text/calendar mime type, whether "
"it needs a terminal is taken from its desktop file."
msgstr "ສະແດງວ່າແອັບພລິເຄຊັນປະຕິທິນເລີ່ມຕົ້ນຕ້ອງການເທີມິນໍເພື່ອເຮັດວຽກບໍ່. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ. ແອັບພລິເຄຊັນປະຕິທິນທີ່ແນະນຳແມ່ນແອັບພລິເຄຊັນທີ່ຈັດການ mime type ປະເພດ text/calendar, ການທີ່ມັນຕ້ອງການເທີມິນໍຫຼືບໍ່ແມ່ນອີງຕາມໄຟລ໌ desktop ຂອງມັນ."

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:37
msgid "Default tasks"
msgstr "ວຽກເລີ່ມຕົ້ນ"

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:38
msgid "Default tasks application."
msgstr "ແອັບພລິເຄຊັນວຽກເລີ່ມຕົ້ນ."

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:44
msgid "Tasks needs terminal"
msgstr "ວຽກຕ້ອງການເທີມິນໍ"

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:45
msgid "Whether the default tasks application needs a terminal to run."
msgstr "ສະແດງວ່າແອັບພລິເຄຊັນວຽກເລີ່ມຕົ້ນຕ້ອງການເທີມິນໍເພື່ອເຮັດວຽກບໍ່."

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:53
msgid "Terminal application"
msgstr "ແອັບພລິເຄຊັນເທີມິນໍ"

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:54
msgid ""
"Terminal program to use when starting applications that require one. "
"DEPRECATED: This key is deprecated and ignored. The default terminal is "
"handled in GIO."
msgstr "ໂປຣແກຣມເທີມິນໍທີ່ຈະໃຊ້ເມື່ອເລີ່ມແອັບພລິເຄຊັນທີ່ຕ້ອງການມັນ. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ. ເທີມິນໍເລີ່ມຕົ້ນຖືກຈັດການໃນ GIO."

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:63
msgid "Exec Arguments"
msgstr "ອາຣ໌ກິວເມັ້ນຂອງ exec"

#: schemas/org.gnome.desktop.default-applications.gschema.xml.in:64
msgid ""
"Argument used to execute programs in the terminal defined by the “exec” key. "
"DEPRECATED: This key is deprecated and ignored. The default terminal and how "
"to invoke it is handled in GIO."
msgstr "ອາຣ໌ກິວເມັ້ນທີ່ໃຊ້ເພື່ອເອີ້ນໃຊ້ໂປຣແກຣມໃນເທີມິນໍທີ່ກຳນົດໂດຍຄີ “exec”. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ. ເທີມິນໍເລີ່ມຕົ້ນ ແລະ ວິທີການເອີ້ນໃຊ້ມັນຖືກຈັດການໃນ GIO."

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:7
msgid "Current input source"
msgstr "ແຫຼ່ງປ້ອນຂໍ້ມູນປັດຈຸບັນ"

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:8
msgid ""
"The zero-based index into the input sources list specifying the current one "
"in effect. The value is automatically capped to remain in the range [0, "
"sources_length) as long as the sources list isn’t empty. DEPRECATED: This "
"key is deprecated and ignored."
msgstr "ດັດຊະນີທີ່ເລີ່ມຈາກສູນໃນລາຍຊື່ແຫຼ່ງປ້ອນຂໍ້ມູນທີ່ກຳນົດແຫຼ່ງປັດຈຸບັນທີ່ກຳລັງໃຊ້ງານ. ຄ່າຈະຖືກຈຳກັດອັດຕະໂນມັດເພື່ອໃຫ້ຢູ່ໃນຂອບເຂດ [0, sources_length) ຕາບໃດທີ່ລາຍຊື່ແຫຼ່ງຂໍ້ມູນບໍ່ວ່າງ. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ."

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:19
msgid "List of input sources"
msgstr "ລາຍຊື່ແຫຼ່ງປ້ອນຂໍ້ມູນ"

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:20
msgid ""
"List of input source identifiers available. Each source is specified as a "
"tuple of 2 strings. The first string is the type and can be one of “xkb” or "
"“ibus”. For “xkb” sources the second string is “xkb_layout+xkb_variant” or "
"just “xkb_layout” if a XKB variant isn’t needed. For “ibus” sources the "
"second string is the IBus engine name. An empty list means that the X "
"server’s current XKB layout and variant won’t be touched and IBus won’t be "
"used."
msgstr "ລາຍຊື່ຕົວລະບຸແຫຼ່ງປ້ອນຂໍ້ມູນທີ່ມີຢູ່. ແຕ່ລະແຫຼ່ງຖືກກຳນົດເປັນຄູ່ຂອງ 2 ສະຕຣິງ. ສະຕຣິງທຳອິດແມ່ນປະເພດ ແລະ ສາມາດເປັນ “xkb” ຫຼື “ibus”. ສຳລັບແຫຼ່ງ “xkb” ສະຕຣິງທີສອງແມ່ນ “xkb_layout+xkb_variant” ຫຼື ພຽງແຕ່ “xkb_layout” ຖ້າບໍ່ຕ້ອງການ XKB variant. ສຳລັບແຫຼ່ງ “ibus” ສະຕຣິງທີສອງແມ່ນຊື່ IBus engine. ລາຍຊື່ທີ່ວ່າງເປົ່າໝາຍຄວາມວ່າຮູບແບບ ແລະ variant XKB ປັດຈຸບັນຂອງ X server ຈະບໍ່ຖືກແຕະຕ້ອງ ແລະ IBus ຈະບໍ່ຖືກໃຊ້."

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:33
msgid "List of most recently used input sources"
msgstr "ລາຍຊື່ແຫຼ່ງປ້ອນຂໍ້ມູນທີ່ໃຊ້ຫຼ້າສຸດ"

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:34
msgid ""
"List of most recently used input sources. The value is in the same format as "
"the available sources list."
msgstr "ລາຍຊື່ແຫຼ່ງປ້ອນຂໍ້ມູນທີ່ໃຊ້ຫຼ້າສຸດ. ຄ່າແມ່ນຢູ່ໃນຮູບແບບດຽວກັນກັບລາຍຊື່ແຫຼ່ງຂໍ້ມູນທີ່ມີຢູ່."

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:41
msgid "List of XKB options"
msgstr "ລາຍຊື່ຕົວເລືອກ XKB"

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:42
msgid ""
"List of XKB options. Each option is an XKB option string as defined by "
"xkeyboard-config’s rules files."
msgstr "ລາຍຊື່ຕົວເລືອກ XKB. ແຕ່ລະຕົວເລືອກແມ່ນສະຕຣິງຕົວເລືອກ XKB ຕາມທີ່ກຳນົດໂດຍໄຟລ໌ກົດລະບຽບຂອງ xkeyboard-config."

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:49
msgid "XKB model to use"
msgstr "ໂມເດລ XKB ທີ່ຈະໃຊ້"

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:50
msgid ""
"The XKB model to use. The value is the same identifier as defined by "
"xkeyboard-config’s geometry files."
msgstr "ໂມເດລ XKB ທີ່ຈະໃຊ້. ຄ່າແມ່ນຕົວລະບຸດຽວກັນກັບທີ່ກຳນົດໂດຍໄຟລ໌ geometry ຂອງ xkeyboard-config."

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:57
msgid "Show all installed input sources"
msgstr "ສະແດງແຫຼ່ງປ້ອນຂໍ້ມູນທີ່ຕິດຕັ້ງທັງໝົດ"

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:58
msgid ""
"Makes all installed input sources available for choosing in System Settings."
msgstr "ເຮັດໃຫ້ແຫຼ່ງປ້ອນຂໍ້ມູນທີ່ຕິດຕັ້ງທັງໝົດສາມາດເລືອກໄດ້ໃນການຕັ້ງຄ່າລະບົບ."

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:65
msgid "Use different input sources for each window"
msgstr "ໃຊ້ແຫຼ່ງປ້ອນຂໍ້ມູນທີ່ແຕກຕ່າງກັນສຳລັບແຕ່ລະໜ້າຕ່າງ"

#: schemas/org.gnome.desktop.input-sources.gschema.xml.in:66
msgid ""
"When enabled, input sources get attached to the currently focused window "
"when activated."
msgstr "ເມື່ອເປີດໃຊ້ງານ, ແຫຼ່ງປ້ອນຂໍ້ມູນຈະຖືກຕິດກັບໜ້າຕ່າງທີ່ກຳລັງໂຟກັສເມື່ອເປີດໃຊ້ງານ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:6
msgid "Enable Toolkit Accessibility"
msgstr "ເປີດໃຊ້ການຊ່ວຍເຫຼືອການເຂົ້າເຖິງຂອງ Toolkit"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:7
msgid "Whether toolkits should load accessibility related modules."
msgstr "ສະແດງວ່າ toolkits ຄວນໂຫຼດໂມດູນທີ່ກ່ຽວຂ້ອງກັບການຊ່ວຍເຫຼືອການເຂົ້າເຖິງບໍ່."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:13
msgid "Enable Animations"
msgstr "ເປີດໃຊ້ອະນິເມຊັນ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:14
msgid ""
"Whether animations should be displayed. Note: This is a global key, it "
"changes the behaviour of the window manager, the panel etc."
msgstr "ສະແດງວ່າຄວນສະແດງອະນິເມຊັນບໍ່. ໝາຍເຫດ: ນີ້ແມ່ນຄີທົ່ວໂລກ, ມັນປ່ຽນແປງພຶດຕິກຳຂອງໂຕຈັດການໜ້າຕ່າງ, ແຖບດ້ານເທິງ, ແລະອື່ນໆ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:21
msgid "Menus Have Tearoff"
msgstr "ເມນູມີໂຕແຍກອອກ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:22
msgid "Whether menus should have a tearoff."
msgstr "ສະແດງວ່າເມນູຄວນມີໂຕແຍກອອກບໍ່."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:28
msgid "Can Change Accels"
msgstr "ສາມາດປ່ຽນຄີລັດໄດ້"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:29
msgid ""
"Whether the user can dynamically type a new accelerator when positioned over "
"an active menuitem."
msgstr "ສະແດງວ່າຜູ້ໃຊ້ສາມາດພິມຄີລັດໃໝ່ໄດ້ທັນທີ ເມື່ອເຄີເຊີຢູ່ເທິງລາຍການເມນູທີ່ກຳລັງໃຊ້ງານຢູ່."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:36
msgid "Toolbar Style"
msgstr "ຮູບແບບແຖບເຄື່ອງມື"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:37
msgid ""
"Toolbar Style. Valid values are “both”, “both-horiz”, “icons”, and “text”."
msgstr "ຮູບແບບແຖບເຄື່ອງມື. ຄ່າທີ່ຖືກຕ້ອງແມ່ນ “both”, “both-horiz”, “icons”, ແລະ “text”."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:44
msgid "Menubar Detachable"
msgstr "ແຖບເມນູສາມາດແຍກອອກໄດ້"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:45
msgid "Whether the user can detach menubars and move them around."
msgstr "ສະແດງວ່າຜູ້ໃຊ້ສາມາດແຍກແຖບເມນູອອກ ແລະ ຍ້າຍໄປມາໄດ້ບໍ່."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:51
msgid "Toolbar Detachable"
msgstr "ແຖບເຄື່ອງມືສາມາດແຍກອອກໄດ້"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:52
msgid "Whether the user can detach toolbars and move them around."
msgstr "ສະແດງວ່າຜູ້ໃຊ້ສາມາດແຍກແຖບເຄື່ອງມືອອກ ແລະ ຍ້າຍໄປມາໄດ້ບໍ່."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:58
msgid "Toolbar Icon Size"
msgstr "ຂະໜາດໄອຄອນແຖບເຄື່ອງມື"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:59
msgid "Size of icons in toolbars, either “small” or “large”."
msgstr "ຂະໜາດຂອງໄອຄອນໃນແຖບເຄື່ອງມື, ສາມາດເປັນ “small” ຫຼື “large”."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:65
msgid "Cursor Blink"
msgstr "ການກະພິບຂອງເຄີເຊີ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:66
msgid "Whether the cursor should blink."
msgstr "ສະແດງວ່າເຄີເຊີຄວນກະພິບບໍ່."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:73
msgid "Cursor Blink Time"
msgstr "ເວລາການກະພິບຂອງເຄີເຊີ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:74
msgid "Length of the cursor blink cycle, in milliseconds."
msgstr "ຄວາມຍາວຂອງຮອບການກະພິບຂອງເຄີເຊີ, ເປັນມິນລິວິນາທີ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:81
msgid "Cursor Blink Timeout"
msgstr "ເວລາຢຸດການກະພິບຂອງເຄີເຊີ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:82
msgid "Time after which the cursor stops blinking, in seconds."
msgstr "ເວລາຫຼັງຈາກນັ້ນເຄີເຊີຈະຢຸດກະພິບ, ເປັນວິນາທີ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:88
msgid "Icon Theme"
msgstr "ຊຸດໄອຄອນ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:89
msgid "Icon theme to use for the panel, nautilus etc."
msgstr "ຊຸດໄອຄອນທີ່ຈະໃຊ້ສຳລັບແຖບດ້ານເທິງ, nautilus, ແລະອື່ນໆ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:95
msgid "Gtk+ Theme"
msgstr "ຊຸດຮູບແບບ Gtk+"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:96
msgid "Basename of the default theme used by gtk+."
msgstr "ຊື່ພື້ນຖານຂອງຊຸດຮູບແບບເລີ່ມຕົ້ນທີ່ໃຊ້ໂດຍ gtk+."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:102
msgid "Gtk+ Keybinding Theme"
msgstr "ຊຸດຮູບແບບການຜູກປຸ່ມ Gtk+"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:103
msgid "Basename of the default keybinding theme used by gtk+."
msgstr "ຊື່ພື້ນຖານຂອງຊຸດຮູບແບບການຜູກປຸ່ມເລີ່ມຕົ້ນທີ່ໃຊ້ໂດຍ gtk+."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:109
msgid "Default font"
msgstr "ຟອນຕ໌ເລີ່ມຕົ້ນ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:110
msgid "Name of the default font used by gtk+."
msgstr "ຊື່ຂອງຟອນຕ໌ເລີ່ມຕົ້ນທີ່ໃຊ້ໂດຍ gtk+."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:116
msgid "Directories with avatar faces"
msgstr "ໂຟລເດີທີ່ມີຮູບໂປຣໄຟລ໌"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:117
msgid ""
"Directories to override the default avatar faces installed by gnome-control-"
"center."
msgstr "ໂຟລເດີເພື່ອປ່ຽນແທນຮູບໂປຣໄຟລ໌ເລີ່ມຕົ້ນທີ່ຕິດຕັ້ງໂດຍ gnome-control-center."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:124
msgid "Text scaling factor"
msgstr "ລະດັບການຂະຫຍາຍຕົວອັກສອນ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:125
msgid ""
"Factor used to enlarge or reduce text display, without changing font size."
msgstr "ລະດັບທີ່ໃຊ້ເພື່ອຂະຫຍາຍ ຫຼື ຫຍໍ້ການສະແດງຜົນຕົວອັກສອນ, ໂດຍບໍ່ປ່ຽນຂະໜາດຟອນຕ໌."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:131
msgid "Window scaling factor"
msgstr "ລະດັບການຂະຫຍາຍໜ້າຕ່າງ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:132
msgid ""
"Integer factor used to scale windows by. For use on high-dpi screens. 0 "
"means pick automatically based on monitor."
msgstr "ລະດັບຈຳນວນຖ້ວນທີ່ໃຊ້ເພື່ອຂະຫຍາຍໜ້າຕ່າງ. ສຳລັບໃຊ້ກັບໜ້າຈໍທີ່ມີຄວາມລະອຽດສູງ. 0 ໝາຍເຖິງການເລືອກອັດຕະໂນມັດໂດຍອີງໃສ່ຈໍພາບ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:139
msgid "GTK IM Preedit Style"
msgstr "ຮູບແບບການແກ້ໄຂລ່ວງໜ້າຂອງ GTK IM"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:140
msgid "Name of the GTK+ input method Preedit Style used by gtk+."
msgstr "ຊື່ຂອງຮູບແບບການແກ້ໄຂລ່ວງໜ້າຂອງວິທີການປ້ອນຂໍ້ມູນ GTK+ ທີ່ໃຊ້ໂດຍ gtk+."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:146
msgid "GTK IM Status Style"
msgstr "ຮູບແບບສະຖານະຂອງ GTK IM"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:147
msgid "Name of the GTK+ input method Status Style used by gtk+."
msgstr "ຊື່ຂອງຮູບແບບສະຖານະຂອງວິທີການປ້ອນຂໍ້ມູນ GTK+ ທີ່ໃຊ້ໂດຍ gtk+."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:153
msgid "GTK IM Module"
msgstr "ໂມດູນ GTK IM"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:154
msgid "Name of the input method module used by GTK+."
msgstr "ຊື່ຂອງໂມດູນວິທີການປ້ອນຂໍ້ມູນທີ່ໃຊ້ໂດຍ GTK+."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:160
msgid "Document font"
msgstr "ຟອນຕ໌ເອກະສານ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:161
msgid "Name of the default font used for reading documents."
msgstr "ຊື່ຂອງຟອນຕ໌ເລີ່ມຕົ້ນທີ່ໃຊ້ສຳລັບການອ່ານເອກະສານ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:167
msgid "Monospace font"
msgstr "ຟອນຕ໌ຄວາມກວ້າງຄົງທີ່"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:168
msgid ""
"Name of a monospaced (fixed-width) font for use in locations like terminals."
msgstr "ຊື່ຂອງຟອນຕ໌ທີ່ມີຄວາມກວ້າງຄົງທີ່ ສຳລັບໃຊ້ໃນບ່ອນຕ່າງໆ ເຊັ່ນ: ເທີມິນໍ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:175
msgid "Menubar accelerator"
msgstr "ຄີລັດແຖບເມນູ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:176
msgid "Keyboard shortcut to open the menu bars."
msgstr "ຄີລັດເພື່ອເປີດແຖບເມນູຕ່າງໆ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:182
msgid "Cursor theme"
msgstr "ຊຸດຮູບແບບເຄີເຊີ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:183
msgid ""
"Cursor theme name. Used only by Xservers that support the Xcursor extension."
msgstr "ຊື່ຊຸດຮູບແບບເຄີເຊີ. ໃຊ້ສະເພາະໂດຍ Xserver ທີ່ຮອງຮັບສ່ວນຂະຫຍາຍ Xcursor."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:187
msgid "Cursor size"
msgstr "ຂະໜາດເຄີເຊີ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:188
msgid "Size of the cursor used as cursor theme."
msgstr "ຂະໜາດຂອງເຄີເຊີທີ່ໃຊ້ເປັນຊຸດຮູບແບບເຄີເຊີ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:192
msgid "Timeout before click repeat"
msgstr "ເວລາລໍຖ້າກ່ອນການຄລິກຊ້ຳ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:193
msgid ""
"Timeout in milliseconds before a click starts repeating (on spinner buttons "
"for example)."
msgstr "ເວລາລໍຖ້າເປັນມິນລິວິນາທີ ກ່ອນທີ່ການຄລິກຈະເລີ່ມຊ້ຳ (ຕົວຢ່າງ: ຢູ່ປຸ່ມເພີ່ມ/ຫຼຸດ)."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:197
msgid "Timeout between click repeats"
msgstr "ໄລຍະຫ່າງລະຫວ່າງການຄລິກຊ້ຳ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:198
msgid ""
"Timeout in milliseconds between repeated clicks when a button is left "
"pressed."
msgstr "ເວລາລໍຖ້າເປັນມິນລິວິນາທີ ລະຫວ່າງການຄລິກຊ້ຳ ເມື່ອກົດປຸ່ມຄ້າງໄວ້."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:202
msgid "Palette used in the color selector"
msgstr "ຊຸດສີທີ່ໃຊ້ໃນໂຕເລືອກສີ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:203
msgid ""
"Palette used in the color selector as defined by the “gtk-color-palette” "
"setting"
msgstr "ຊຸດສີທີ່ໃຊ້ໃນໂຕເລືອກສີ ຕາມທີ່ກຳນົດໂດຍການຕັ້ງຄ່າ “gtk-color-palette”"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:207
msgid "List of symbolic names and color equivalents"
msgstr "ລາຍຊື່ຊື່ສັນຍາລັກ ແລະ ສີທີ່ທຽບເທົ່າ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:208
msgid ""
"A “\\n” separated list of “name:color” as defined by the “gtk-color-scheme” "
"setting"
msgstr "ລາຍຊື່ “name:color” ທີ່ແຍກກັນດ້ວຍ “\\n” ຕາມທີ່ກຳນົດໂດຍການຕັ້ງຄ່າ “gtk-color-scheme”"

#. TRANSLATORS: select your locale's default clock format, this should be '12h' or '24h' (with the quotes!)
#: schemas/org.gnome.desktop.interface.gschema.xml.in:212
msgid "'24h'"
msgstr "'24h'"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:213
#: schemas/org.gnome.desktop.interface.gschema.xml.in:214
msgid "Whether the clock displays in 24h or 12h format"
msgstr "ສະແດງວ່າໂມງຈະສະແດງໃນຮູບແບບ 24 ຊົ່ວໂມງ ຫຼື 12 ຊົ່ວໂມງ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:220
msgid "Whether the clock shows seconds"
msgstr "ສະແດງວ່າໂມງຈະສະແດງວິນາທີບໍ່"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:221
msgid "If true, display seconds in the clock."
msgstr "ຖ້າເປັນ true, ຈະສະແດງວິນາທີໃນໂມງ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:227
msgid "Show date in clock"
msgstr "ສະແດງວັນທີໃນໂມງ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:228
msgid "If true, display date in the clock, in addition to time."
msgstr "ຖ້າເປັນ true, ຈະສະແດງວັນທີໃນໂມງ, ນອກເໜືອຈາກເວລາ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:234
msgid "Show weekday in clock"
msgstr "ສະແດງມື້ຂອງອາທິດໃນໂມງ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:235
msgid "If true, display weekday in the clock, in addition to time."
msgstr "ຖ້າເປັນ true, ຈະສະແດງມື້ຂອງອາທິດໃນໂມງ, ນອກເໜືອຈາກເວລາ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:241
msgid "Enable hot corners"
msgstr "ເປີດໃຊ້ງານມຸມຮ້ອນ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:242
msgid ""
"If true, the activities overview can be accessed by moving the mouse to the "
"top-left corner."
msgstr "ຖ້າເປັນ true, ສາມາດເຂົ້າເຖິງພາບລວມກິດຈະກຳໄດ້ໂດຍການເລື່ອນເມົ້າສ໌ໄປທີ່ມຸມເທິງຊ້າຍ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:249
msgid "Show battery percentage"
msgstr "ສະແດງເປີເຊັນແບັດເຕີຣີ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:250
msgid ""
"If true, display battery percentage in the status menu, in addition to the "
"icon."
msgstr "ຖ້າເປັນ true, ຈະສະແດງເປີເຊັນແບັດເຕີຣີໃນເມນູສະຖານະ, ນອກເໜືອຈາກໄອຄອນ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:256
msgid "Enable the primary paste selection"
msgstr "ເປີດໃຊ້ການວາງຂໍ້ຄວາມຫຼັກ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:257
msgid ""
"If true, gtk+ uses the primary paste selection, usually triggered by a "
"middle mouse button click."
msgstr "ຖ້າເປັນ true, gtk+ ຈະໃຊ້ການວາງຂໍ້ຄວາມຫຼັກ, ເຊິ່ງປົກກະຕິແລ້ວຈະຖືກເອີ້ນໃຊ້ໂດຍການຄລິກປຸ່ມກາງຂອງເມົ້າສ໌."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:263
msgid "Allow overlay scrolling"
msgstr "ອະນຸຍາດການເລື່ອນແບບໂອເວີເລ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:264
msgid ""
"Whether scrollbars should be overlayed as indicators. Depending on input "
"devices in use, permanent scrollbars may still be displayed."
msgstr "ສະແດງວ່າແຖບເລື່ອນຄວນຖືກສະແດງເປັນຕົວຊີ້ບອກແບບໂອເວີເລບໍ່. ຂຶ້ນຢູ່ກັບອຸປະກອນປ້ອນຂໍ້ມູນທີ່ໃຊ້, ແຖບເລື່ອນແບບຖາວອນອາດຈະຍັງຖືກສະແດງຢູ່."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:272
msgid "Highlights the current location of the pointer."
msgstr "ສະແດງຈຸດເດັ່ນຂອງຕຳແໜ່ງປັດຈຸບັນຂອງຕົວຊີ້."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:273
msgid ""
"If true, pressing a key will highlight the current pointer location on "
"screen."
msgstr "ຖ້າເປັນ true, ການກົດປຸ່ມຈະສະແດງຈຸດເດັ່ນຂອງຕຳແໜ່ງປັດຈຸບັນຂອງຕົວຊີ້ເທິງໜ້າຈໍ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:279
msgid "Antialiasing"
msgstr "ການລົບຂອບຫຍັກ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:280
msgid ""
"The type of antialiasing to use when rendering fonts. Possible values are: "
"“none” for no antialiasing, “grayscale” for standard grayscale antialiasing, "
"and “rgba” for subpixel antialiasing (LCD screens only)."
msgstr "ປະເພດຂອງການລົບຂອບຫຍັກທີ່ຈະໃຊ້ເມື່ອສະແດງຜົນຟອນຕ໌. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ: “none” ສຳລັບບໍ່ມີການລົບຂອບຫຍັກ, “grayscale” ສຳລັບການລົບຂອບຫຍັກແບບສີເທົາມາດຕະຖານ, ແລະ “rgba” ສຳລັບການລົບຂອບຫຍັກແບບ subpixel (ສະເພາະໜ້າຈໍ LCD)."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:286
msgid "Hinting"
msgstr "ການປັບຄວາມຄົມຊັດ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:287
msgid ""
"The type of hinting to use when rendering fonts. Possible values are: “none” "
"for no hinting and “slight” for fitting only to the Y-axis like Microsoft’s "
"ClearType, DirectWrite and Adobe’s proprietary font rendering engine. "
"Ignores native hinting within the font, generates hints algorithmically. "
"Used on Ubuntu by default. Recommended. The meaning of “medium” and “full” "
"depends on the font format (.ttf, .otf, .pfa/.pfb) and the installed version "
"of FreeType. They usually try to fit glyphs to both the X and the Y axis "
"(except for .otf: Y-only). This can lead to distortion and/or inconsistent "
"rendering depending on the quality of the font, the font format and the "
"state of FreeType’s font engines."
msgstr "ປະເພດຂອງການປັບຄວາມຄົມຊັດທີ່ຈະໃຊ້ເມື່ອສະແດງຜົນຟອນຕ໌. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ: “none” ສຳລັບບໍ່ມີການປັບ, ແລະ “slight” ສຳລັບການປັບໃຫ້ພໍດີກັບແກນ Y ເທົ່ານັ້ນ ເຊັ່ນ ClearType ຂອງ Microsoft, DirectWrite ແລະ ເຄື່ອງມືສະແດງຜົນຟອນຕ໌ຂອງ Adobe. ມັນຈະບໍ່ສົນໃຈການປັບຄວາມຄົມຊັດທີ່ມີຢູ່ໃນຟອນຕ໌, ແຕ່ຈະສ້າງຄຳແນະນຳຂຶ້ນມາຕາມອັນກໍຣິທຶມ. ຖືກໃຊ້ເປັນຄ່າເລີ່ມຕົ້ນໃນ Ubuntu. ແນະນຳ. ຄວາມໝາຍຂອງ “medium” ແລະ “full” ຂຶ້ນຢູ່ກັບຮູບແບບຂອງຟອນຕ໌ (.ttf, .otf, .pfa/.pfb) ແລະ ເວີຊັນຂອງ FreeType ທີ່ຕິດຕັ້ງ. ໂດຍປົກກະຕິແລ້ວ, ມັນຈະພະຍາຍາມປັບຕົວອັກສອນໃຫ້ພໍດີກັບທັງແກນ X ແລະ Y (ຍົກເວັ້ນ .otf: ສະເພາະແກນ Y). ນີ້ອາດຈະເຮັດໃຫ້ເກີດການບິດເບືອນ ແລະ/ຫຼື ການສະແດງຜົນທີ່ບໍ່ສະໝ່ຳສະເໝີ ຂຶ້ນຢູ່ກັບຄຸນນະພາບຂອງຟອນຕ໌, ຮູບແບບຂອງຟອນຕ໌ ແລະ ສະຖານະຂອງເຄື່ອງມືຟອນຕ໌ຂອງ FreeType."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:293
msgid "RGBA order"
msgstr "ລຳດັບ RGBA"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:294
msgid ""
"The order of subpixel elements on an LCD screen; only used when antialiasing "
"is set to “rgba”. Possible values are: “rgb” for red on left (most common), "
"“bgr” for blue on left, “vrgb” for red on top, “vbgr” for red on bottom."
msgstr "ລຳດັບຂອງອົງປະກອບ subpixel ເທິງໜ້າຈໍ LCD; ໃຊ້ສະເພາະເມື່ອການລົບຂອບຫຍັກຖືກຕັ້ງເປັນ “rgba”. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ: “rgb” ສຳລັບສີແດງຢູ່ດ້ານຊ້າຍ (ພົບເຫັນຫຼາຍທີ່ສຸດ), “bgr” ສຳລັບສີຟ້າຢູ່ດ້ານຊ້າຍ, “vrgb” ສຳລັບສີແດງຢູ່ດ້ານເທິງ, “vbgr” ສຳລັບສີແດງຢູ່ດ້ານລຸ່ມ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:300
msgid "Color scheme"
msgstr "ຊຸດສີ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:301
msgid ""
"The preferred color scheme for the user interface. Valid values are "
"“default”, “prefer-dark”, “prefer-light”."
msgstr "ຊຸດສີທີ່ແນະນຳສຳລັບສ່ວນຕິດຕໍ່ຜູ້ໃຊ້. ຄ່າທີ່ຖືກຕ້ອງແມ່ນ “default”, “prefer-dark”, “prefer-light”."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:307
msgid "Font rendering"
msgstr "ການສະແດງຜົນຟອນຕ໌"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:308
msgid ""
"Preference to indicate whether font rendering should follow the low-level "
"`font-hinting` and `font-antialiasing` and `font-rgba-order` settings, or "
"take environmental factors such as screen resolution and scaling into "
"account. Possible values are: \"manual\" for respecting the low-level "
"settings, or \"automatic\" for letting the toolkit make its own decisions."
msgstr "ຕົວເລືອກເພື່ອບົ່ງບອກວ່າການສະແດງຜົນຟອນຕ໌ຄວນປະຕິບັດຕາມການຕັ້ງຄ່າລະດັບຕ່ຳ `font-hinting`, `font-antialiasing` ແລະ `font-rgba-order`, ຫຼື ຄວນພິຈາລະນາປັດໄຈດ້ານສະພາບແວດລ້ອມເຊັ່ນ ຄວາມລະອຽດໜ້າຈໍ ແລະ ການຂະຫຍາຍ. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ: \"manual\" ສຳລັບການປະຕິບັດຕາມການຕັ້ງຄ່າລະດັບຕ່ຳ, ຫຼື \"automatic\" ສຳລັບການໃຫ້ toolkit ຕັດສິນໃຈເອງ."

#: schemas/org.gnome.desktop.interface.gschema.xml.in:316
msgid "Accent color"
msgstr "ສີເນັ້ນ"

#: schemas/org.gnome.desktop.interface.gschema.xml.in:317
msgid ""
"The preferred accent color for the user interface. Valid values are "
"\"blue\", \"teal\", \"green\", \"yellow\", \"orange\", \"red\", \"pink\", "
"\"purple\", \"slate\"."
msgstr "ສີເນັ້ນທີ່ແນະນຳສຳລັບສ່ວນຕິດຕໍ່ຜູ້ໃຊ້. ຄ່າທີ່ຖືກຕ້ອງແມ່ນ \"blue\", \"teal\", \"green\", \"yellow\", \"orange\", \"red\", \"pink\", \"purple\", \"slate\"."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:6
msgid "Disable command line"
msgstr "ປິດໃຊ້ງານເສັ້ນຄຳສັ່ງ"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:7
msgid ""
"Prevent the user from accessing the terminal or specifying a command line to "
"be executed. For example, this would disable access to the panel’s “Run "
"Application” dialog."
msgstr "ປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ເຂົ້າເຖິງເທີມິນໍ ຫຼື ລະບຸເສັ້ນຄຳສັ່ງທີ່ຈະເອີ້ນໃຊ້. ຕົວຢ່າງ, ນີ້ຈະປິດການເຂົ້າເຖິງກ່ອງໂຕ້ຕອບ “Run Application” ຂອງແຖບດ້ານເທິງ."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:15
msgid "Disable saving files to disk"
msgstr "ປິດໃຊ້ງານການບັນທຶກໄຟລ໌ລົງດິສກ໌"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:16
msgid ""
"Prevent the user from saving files to disk. For example, this would disable "
"access to all applications’ “Save as” dialogs."
msgstr "ປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ບັນທຶກໄຟລ໌ລົງດິສກ໌. ຕົວຢ່າງ, ນີ້ຈະປິດການເຂົ້າເຖິງກ່ອງໂຕ້ຕອບ “Save as” ຂອງທຸກແອັບພລິເຄຊັນ."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:23
msgid "Disable printing"
msgstr "ປິດໃຊ້ງານການພິມ"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:24
msgid ""
"Prevent the user from printing. For example, this would disable access to "
"all applications’ “Print” dialogs."
msgstr "ປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ພິມ. ຕົວຢ່າງ, ນີ້ຈະປິດການເຂົ້າເຖິງກ່ອງໂຕ້ຕອບ “Print” ຂອງທຸກແອັບພລິເຄຊັນ."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:31
msgid "Disable print setup"
msgstr "ປິດໃຊ້ງານການຕັ້ງຄ່າການພິມ"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:32
msgid ""
"Prevent the user from modifying print settings. For example, this would "
"disable access to all applications’ “Print Setup” dialogs."
msgstr "ປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ແກ້ໄຂການຕັ້ງຄ່າການພິມ. ຕົວຢ່າງ, ນີ້ຈະປິດການເຂົ້າເຖິງກ່ອງໂຕ້ຕອບ “Print Setup” ຂອງທຸກແອັບພລິເຄຊັນ."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:39
msgid "Disable user switching"
msgstr "ປິດໃຊ້ງານການສະຫຼັບຜູ້ໃຊ້"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:40
msgid ""
"Prevent the user from switching to another account while their session is "
"active."
msgstr "ປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ສະຫຼັບໄປບັນຊີອື່ນໃນຂະນະທີ່ເຊສຊັນຂອງພວກເຂົາກຳລັງໃຊ້ງານຢູ່."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:47
msgid "Disable lock screen"
msgstr "ປິດໃຊ້ງານການລັອກໜ້າຈໍ"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:48
msgid "Prevent the user from locking their screen."
msgstr "ປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ລັອກໜ້າຈໍຂອງພວກເຂົາ."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:54
msgid "Disable URL and MIME type handlers"
msgstr "ປິດໃຊ້ງານໂຕຈັດການ URL ແລະ MIME type"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:55
msgid "Prevent running any URL or MIME type handler applications."
msgstr "ປ້ອງກັນການເປີດໃຊ້ແອັບພລິເຄຊັນທີ່ເປັນໂຕຈັດການ URL ຫຼື MIME type."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:61
msgid "Disable log out"
msgstr "ປິດໃຊ້ງານການອອກຈາກລະບົບ"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:62
msgid "Prevent the user from logging out."
msgstr "ປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ອອກຈາກລະບົບ."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:68
msgid "Disable user administration"
msgstr "ປິດໃຊ້ງານການບໍລິຫານຜູ້ໃຊ້"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:69
msgid ""
"Stop the user from modifying user accounts. By default, we allow adding and "
"removing users, as well as changing other users settings."
msgstr "ຢຸດບໍ່ໃຫ້ຜູ້ໃຊ້ແກ້ໄຂບັນຊີຜູ້ໃຊ້. ໂດຍຄ່າເລີ່ມຕົ້ນ, ພວກເຮົາອະນຸຍາດໃຫ້ເພີ່ມ ແລະ ລຶບຜູ້ໃຊ້, ລວມທັງການປ່ຽນແປງການຕັ້ງຄ່າຂອງຜູ້ໃຊ້ອື່ນ."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:76
msgid "Mount removable storage devices as read-only"
msgstr "ເຊື່ອມຕໍ່ອຸປະກອນເກັບຂໍ້ມູນແບບຖອດໄດ້ເປັນແບບອ່ານຢ່າງດຽວ"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:77
msgid ""
"Prevent users from writing or modifying files on removable storage devices "
"(i.e. flash disks, mobile phones, cameras)."
msgstr "ປ້ອງກັນບໍ່ໃຫ້ຜູ້ໃຊ້ຂຽນ ຫຼື ແກ້ໄຂໄຟລ໌ໃນອຸປະກອນເກັບຂໍ້ມູນແບບຖອດໄດ້ (ເຊັ່ນ: ແຟລຊໄດຣຟ໌, ໂທລະສັບມືຖື, ກ້ອງຖ່າຍຮູບ)."

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:84
msgid "Disable password showing"
msgstr "ປິດໃຊ້ງານການສະແດງລະຫັດຜ່ານ"

#: schemas/org.gnome.desktop.lockdown.gschema.xml.in:85
msgid "Disable the \"Show Password\" menu item in password entries."
msgstr "ປິດໃຊ້ງານລາຍການເມນູ \"ສະແດງລະຫັດຜ່ານ\" ໃນຊ່ອງປ້ອນລະຫັດຜ່ານ."

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:6
msgid "Whether to automatically mount media"
msgstr "ສະແດງວ່າຈະເຊື່ອມຕໍ່ສື່ອັດຕະໂນມັດບໍ່"

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:7
msgid ""
"If set to true, then Nautilus will automatically mount media such as user-"
"visible hard disks and removable media on start-up and media insertion."
msgstr "ຖ້າຕັ້ງເປັນ true, Nautilus ຈະເຊື່ອມຕໍ່ສື່ອັດຕະໂນມັດ ເຊັ່ນ ຮາດດິສກ໌ທີ່ຜູ້ໃຊ້ເຫັນໄດ້ ແລະ ສື່ແບບຖອດໄດ້ ເມື່ອເລີ່ມລະບົບ ແລະ ເມື່ອສຽບສື່."

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:11
msgid "Whether to automatically open a folder for automounted media"
msgstr "ສະແດງວ່າຈະເປີດໂຟລເດີອັດຕະໂນມັດສຳລັບສື່ທີ່ເຊື່ອມຕໍ່ອັດຕະໂນມັດບໍ່"

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:12
msgid ""
"If set to true, then Nautilus will automatically open a folder when media is "
"automounted. This only applies to media where no known x-content/* type was "
"detected; for media where a known x-content type is detected, the user "
"configurable action will be taken instead."
msgstr "ຖ້າຕັ້ງເປັນ true, Nautilus ຈະເປີດໂຟລເດີອັດຕະໂນມັດເມື່ອສື່ຖືກເຊື່ອມຕໍ່ອັດຕະໂນມັດ. ນີ້ໃຊ້ສະເພາະກັບສື່ທີ່ບໍ່ກວດພົບປະເພດ x-content/* ທີ່ຮູ້ຈັກ; ສຳລັບສື່ທີ່ກວດພົບປະເພດ x-content ທີ່ຮູ້ຈັກ, ການກະທຳທີ່ຜູ້ໃຊ້ກຳນົດໄວ້ຈະຖືກປະຕິບັດແທນ."

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:16
msgid "Never prompt or autorun/autostart programs when media are inserted"
msgstr "ບໍ່ຕ້ອງຖາມ ຫຼື ເປີດ/ເລີ່ມໂປຣແກຣມອັດຕະໂນມັດເມື່ອສຽບສື່"

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:17
msgid ""
"If set to true, then Nautilus will never prompt nor autorun/autostart "
"programs when a medium is inserted."
msgstr "ຖ້າຕັ້ງເປັນ true, Nautilus ຈະບໍ່ຖາມ ຫຼື ເປີດ/ເລີ່ມໂປຣແກຣມອັດຕະໂນມັດເມື່ອມີການສຽບສື່."

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:21
msgid ""
"List of x-content/* types where the preferred application will be launched"
msgstr "ລາຍຊື່ປະເພດ x-content/* ທີ່ແອັບພລິເຄຊັນທີ່ຕ້ອງການຈະຖືກເປີດ"

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:22
msgid ""
"List of x-content/* types for which the user have chosen to start an "
"application in the preference capplet. The preferred application for the "
"given type will be started on insertion on media matching these types."
msgstr "ລາຍຊື່ປະເພດ x-content/* ທີ່ຜູ້ໃຊ້ໄດ້ເລືອກໃຫ້ເລີ່ມແອັບພລິເຄຊັນໃນການຕັ້ງຄ່າ. ແອັບພລິເຄຊັນທີ່ຕ້ອງການສຳລັບປະເພດດັ່ງກ່າວຈະຖືກເລີ່ມເມື່ອສຽບສື່ທີ່ກົງກັບປະເພດເຫຼົ່ານີ້."

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:26
msgid "List of x-content/* types set to “Do Nothing”"
msgstr "ລາຍຊື່ປະເພດ x-content/* ທີ່ຕັ້ງເປັນ “ບໍ່ເຮັດຫຍັງ”"

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:27
msgid ""
"List of x-content/* types for which the user have chosen “Do Nothing” in the "
"preference capplet. No prompt will be shown nor will any matching "
"application be started on insertion of media matching these types."
msgstr "ລາຍຊື່ປະເພດ x-content/* ທີ່ຜູ້ໃຊ້ໄດ້ເລືອກ “ບໍ່ເຮັດຫຍັງ” ໃນການຕັ້ງຄ່າ. ຈະບໍ່ມີການຖາມ ແລະ ບໍ່ມີແອັບພລິເຄຊັນທີ່ກົງກັນໃດໆຖືກເລີ່ມເມື່ອສຽບສື່ທີ່ກົງກັບປະເພດເຫຼົ່ານີ້."

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:31
msgid "List of x-content/* types set to “Open Folder”"
msgstr "ລາຍຊື່ປະເພດ x-content/* ທີ່ຕັ້ງເປັນ “ເປີດໂຟລເດີ”"

#: schemas/org.gnome.desktop.media-handling.gschema.xml.in:32
msgid ""
"List of x-content/* types for which the user have chosen “Open Folder” in "
"the preferences capplet. A folder window will be opened on insertion of "
"media matching these types."
msgstr "ລາຍຊື່ປະເພດ x-content/* ທີ່ຜູ້ໃຊ້ໄດ້ເລືອກ “ເປີດໂຟລເດີ” ໃນການຕັ້ງຄ່າ. ໜ້າຕ່າງໂຟລເດີຈະຖືກເປີດເມື່ອສຽບສື່ທີ່ກົງກັບປະເພດເຫຼົ່ານີ້."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:6
#: schemas/org.gnome.desktop.notifications.gschema.xml.in:55
msgid "Show notification banners"
msgstr "ສະແດງປ້າຍແຈ້ງເຕືອນ"

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:7
msgid "Whether notification banners are visible for application notifications."
msgstr "ສະແດງວ່າປ້າຍແຈ້ງເຕືອນຈະປາກົດສຳລັບການແຈ້ງເຕືອນຂອງແອັບພລິເຄຊັນບໍ່."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:14
msgid "Show notifications in the lock screen"
msgstr "ສະແດງການແຈ້ງເຕືອນໃນໜ້າຈໍລັອກ"

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:15
msgid "Whether notifications are shown in the lock screen or not."
msgstr "ສະແດງວ່າການແຈ້ງເຕືອນຈະຖືກສະແດງໃນໜ້າຈໍລັອກບໍ່."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:31
msgid "Application ID"
msgstr "ID ຂອງແອັບພລິເຄຊັນ"

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:32
msgid "The application that this policy is for."
msgstr "ແອັບພລິເຄຊັນທີ່ນະໂຍບາຍນີ້ໃຊ້ສຳລັບ."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:39
msgid "Enable notifications"
msgstr "ເປີດໃຊ້ການແຈ້ງເຕືອນ"

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:40
msgid "Whether notifications are globally enabled for this application."
msgstr "ສະແດງວ່າການແຈ້ງເຕືອນຖືກເປີດໃຊ້ງານທົ່ວໄປສຳລັບແອັບພລິເຄຊັນນີ້ບໍ່."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:47
msgid "Enable sound alerts"
msgstr "ເປີດໃຊ້ການແຈ້ງເຕືອນດ້ວຍສຽງ"

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:48
msgid "Whether notifications should be accompanied by sound alerts."
msgstr "ສະແດງວ່າການແຈ້ງເຕືອນຄວນມີສຽງປະກອບບໍ່."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:56
msgid ""
"Whether notification banners for this application are shown or not. Does not "
"affect clicking on message tray buttons."
msgstr "ສະແດງວ່າປ້າຍແຈ້ງເຕືອນສຳລັບແອັບພລິເຄຊັນນີ້ຈະຖືກສະແດງບໍ່. ບໍ່ມີຜົນຕໍ່ການຄລິກປຸ່ມໃນຖາດຂໍ້ຄວາມ."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:64
msgid "Force automatic expanding of banners"
msgstr "ບັງຄັບການຂະຫຍາຍປ້າຍແຈ້ງເຕືອນອັດຕະໂນມັດ"

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:65
msgid ""
"Whether notifications from this application are expanded automatically when "
"in banner mode."
msgstr "ສະແດງວ່າການແຈ້ງເຕືອນຈາກແອັບພລິເຄຊັນນີ້ຈະຖືກຂະຫຍາຍອັດຕະໂນມັດບໍ່ເມື່ອຢູ່ໃນໂໝດປ້າຍແຈ້ງເຕືອນ."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:72
msgid "Show in the lock screen"
msgstr "ສະແດງໃນໜ້າຈໍລັອກ"

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:73
msgid ""
"Whether notifications from this application are shown when the screen is "
"locked."
msgstr "ສະແດງວ່າການແຈ້ງເຕືອນຈາກແອັບພລິເຄຊັນນີ້ຈະຖືກສະແດງບໍ່ເມື່ອໜ້າຈໍຖືກລັອກ."

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:80
msgid "Show details in the lock screen"
msgstr "ສະແດງລາຍລະອຽດໃນໜ້າຈໍລັອກ"

#: schemas/org.gnome.desktop.notifications.gschema.xml.in:81
msgid ""
"Whether the summary and body of notifications from this application will be "
"visible in the locked screen."
msgstr "ສະແດງວ່າບົດສະຫຼຸບ ແລະ ເນື້ອໃນຂອງການແຈ້ງເຕືອນຈາກແອັບພລິເຄຊັນນີ້ຈະປາກົດໃນໜ້າຈໍທີ່ລັອກໄວ້ບໍ່."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:15
msgid "Whether edge scrolling is enabled"
msgstr "ສະແດງວ່າການເລື່ອນດ້ວຍຂອບເປີດໃຊ້ຢູ່ບໍ່"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:16
msgid ""
"When enabled, touchpads that support edge scrolling will have that feature "
"enabled."
msgstr "ເມື່ອເປີດໃຊ້ງານ, ທັດຊ໌ແພັດທີ່ຮອງຮັບການເລື່ອນດ້ວຍຂອບຈະມີຄຸນສົມບັດນັ້ນເປີດໃຊ້ງານ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:20
msgid "Whether two-finger scrolling is enabled"
msgstr "ສະແດງວ່າການເລື່ອນດ້ວຍສອງນິ້ວເປີດໃຊ້ຢູ່ບໍ່"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:21
msgid ""
"When enabled, touchpads that support two-finger scrolling will have that "
"feature enabled."
msgstr "ເມື່ອເປີດໃຊ້ງານ, ທັດຊ໌ແພັດທີ່ຮອງຮັບການເລື່ອນດ້ວຍສອງນິ້ວຈະມີຄຸນສົມບັດນັ້ນເປີດໃຊ້ງານ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:25
msgid "Whether to disable the touchpad while typing"
msgstr "ສະແດງວ່າຈະປິດທັດຊ໌ແພັດໃນຂະນະທີ່ພິມບໍ່"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:26
msgid "When enabled, touchpads will be disabled while typing on the keyboard."
msgstr "ເມື່ອເປີດໃຊ້ງານ, ທັດຊ໌ແພັດຈະຖືກປິດໃນຂະນະທີ່ພິມເທິງຄີບອດ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:30
msgid "Enable mouse clicks with touchpad"
msgstr "ເປີດໃຊ້ການຄລິກເມົ້າສ໌ດ້ວຍທັດຊ໌ແພັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:31
msgid ""
"Set this to TRUE to be able to send mouse clicks by tapping on the touchpad."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອໃຫ້ສາມາດສົ່ງການຄລິກເມົ້າສ໌ໂດຍການແຕະໃສ່ທັດຊ໌ແພັດ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:35
msgid "Tap Button Map"
msgstr "ການຈັບຄູ່ປຸ່ມແຕະ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:36
msgid ""
"Defines the mapping between the number of fingers and touchpad buttons. The "
"default is to have a 1, 2 and 3 finger tap to map to the left, right and "
"middle button (\"lrm\"), respectively."
msgstr "ກຳນົດການຈັບຄູ່ລະຫວ່າງຈຳນວນນິ້ວ ແລະ ປຸ່ມທັດຊ໌ແພັດ. ຄ່າເລີ່ມຕົ້ນແມ່ນການແຕະດ້ວຍ 1, 2 ແລະ 3 ນິ້ວ ເພື່ອຈັບຄູ່ກັບປຸ່ມຊ້າຍ, ຂວາ ແລະ ກາງ (\"lrm\") ຕາມລຳດັບ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:40
msgid "Enable tap-and-drag with touchpad"
msgstr "ເປີດໃຊ້ການແຕະແລ້ວລາກດ້ວຍທັດຊ໌ແພັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:41
msgid ""
"Set this to TRUE to be able to start a drag by tapping and immediately "
"moving the finger that’s now pressed on the touchpad."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອໃຫ້ສາມາດເລີ່ມການລາກໂດຍການແຕະ ແລະ ເລື່ອນນິ້ວທີ່ກຳລັງກົດຢູ່ເທິງທັດຊ໌ແພັດທັນທີ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:45
msgid "Enable tap-and-drag-lock with touchpad"
msgstr "ເປີດໃຊ້ການລັອກການແຕະແລ້ວລາກດ້ວຍທັດຊ໌ແພັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:46
msgid ""
"Set this to TRUE to lock the dragging process within a short timeout when "
"the finger is lifted on the touchpad and the tap-and-drag setting is enabled."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອລັອກຂະບວນການລາກພາຍໃນເວລາສັ້ນໆ ເມື່ອຍົກນິ້ວອອກຈາກທັດຊ໌ແພັດ ແລະ ການຕັ້ງຄ່າການແຕະແລ້ວລາກເປີດຢູ່."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:50
msgid "Touchpad enabled"
msgstr "ເປີດໃຊ້ທັດຊ໌ແພັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:51
msgid "Defines the situations in which the touchpad is enabled."
msgstr "ກຳນົດສະຖານະການທີ່ທັດຊ໌ແພັດຈະຖືກເປີດໃຊ້ງານ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:55
msgid "Touchpad button orientation"
msgstr "ທິດທາງປຸ່ມທັດຊ໌ແພັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:56
msgid ""
"Swap left and right mouse buttons for left-handed mice with “left”, “right” "
"for right-handed, “mouse” to follow the mouse setting."
msgstr "ສັບປ່ຽນປຸ່ມເມົ້າສ໌ຊ້າຍ ແລະ ຂວາສຳລັບຜູ້ທີ່ຖະໜັດຊ້າຍດ້ວຍ “left”, “right” ສຳລັບຜູ້ທີ່ຖະໜັດຂວາ, “mouse” ເພື່ອປະຕິບັດຕາມການຕັ້ງຄ່າຂອງເມົ້າສ໌."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:60
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:131
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:261
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:279
msgid "Acceleration profile"
msgstr "ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:61
msgid ""
"Acceleration profile used for connected touchpads. The acceleration profile "
"can be set to either default (“default”) which uses the default acceleration "
"profile for each device, flat (“flat”), which accelerates by a device "
"specific constant factor derived from the configured pointer speed, or "
"adaptive (“adaptive”) which adapts the acceleration depending on the mouse "
"movement. If a touchpad doesn’t support the configured profile, “default” "
"will be used."
msgstr "ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວທີ່ໃຊ້ສຳລັບທັດຊ໌ແພັດທີ່ເຊື່ອມຕໍ່. ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວສາມາດຕັ້ງເປັນ “default” ເຊິ່ງໃຊ້ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວເລີ່ມຕົ້ນສຳລັບແຕ່ລະອຸປະກອນ, “flat” ເຊິ່ງເລັ່ງຄວາມໄວໂດຍປັດໄຈຄົງທີ່ຂອງອຸປະກອນທີ່ໄດ້ມາຈາກຄວາມໄວຕົວຊີ້ທີ່ກຳນົດ, ຫຼື “adaptive” ເຊິ່ງປັບການເລັ່ງຄວາມໄວຕາມການເຄື່ອນທີ່ຂອງເມົ້າສ໌. ຖ້າທັດຊ໌ແພັດບໍ່ຮອງຮັບໂປຣໄຟລ໌ທີ່ກຳນົດ, “default” ຈະຖືກໃຊ້."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:65
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:120
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:273
msgid "Pointer speed"
msgstr "ຄວາມໄວຕົວຊີ້"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:66
msgid ""
"Pointer speed for the touchpad. Accepted values are in the [-1..1] range "
"(from “unaccelerated” to “fast”). A value of 0 is the system default."
msgstr "ຄວາມໄວຕົວຊີ້ສຳລັບທັດຊ໌ແພັດ. ຄ່າທີ່ຍອມຮັບໄດ້ຢູ່ໃນຊ່ວງ [-1..1] (ຈາກ “ບໍ່ເລັ່ງ” ຫາ “ໄວ”). ຄ່າ 0 ແມ່ນຄ່າເລີ່ມຕົ້ນຂອງລະບົບ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:71
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:126
msgid "Natural scrolling"
msgstr "ການເລື່ອນແບບທຳມະຊາດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:72
msgid "Set this to TRUE to enable natural (reverse) scrolling for touchpads."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອເປີດໃຊ້ການເລື່ອນແບບທຳມະຊາດ (ປີ້ນກັບ) ສຳລັບທັດຊ໌ແພັດ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:76
msgid "Click method"
msgstr "ວິທີການຄລິກ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:77
msgid ""
"How to generate software-emulated buttons, either disabled (“none”), through "
"specific areas (“areas”), number of fingers (“fingers”) or left as hardware "
"default (“default”)."
msgstr "ວິທີການສ້າງປຸ່ມຈຳລອງດ້ວຍຊອບແວ, ສາມາດປິດ (“none”), ຜ່ານພື້ນທີ່ສະເພາະ (“areas”), ຈຳນວນນິ້ວ (“fingers”) ຫຼື ປະໄວ້ເປັນຄ່າເລີ່ມຕົ້ນຂອງຮາດແວ (“default”)."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:81
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:136
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:266
msgid "Emulate middle click"
msgstr "ຈຳລອງການຄລິກກາງ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:82
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:137
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:267
msgid ""
"Set this to TRUE to enable middle click during simultaneous left and right "
"click."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອເປີດໃຊ້ການຄລິກກາງໃນຂະນະທີ່ຄລິກຊ້າຍ ແລະ ຂວາພ້ອມກັນ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:88
msgid "Keyboard repeat"
msgstr "ການກົດປຸ່ມຄີບອດຊ້ຳ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:89
msgid "Set this to TRUE to enable keyboard repeat."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອເປີດໃຊ້ການກົດປຸ່ມຄີບອດຊ້ຳ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:93
msgid "Key Repeat Interval"
msgstr "ໄລຍະຫ່າງການກົດປຸ່ມຊ້ຳ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:94
msgid "Delay between repeats in milliseconds."
msgstr "ການໜ່ວງເວລາລະຫວ່າງການກົດຊ້ຳເປັນມິນລິວິນາທີ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:98
msgid "Initial Key Repeat Delay"
msgstr "ການໜ່ວງເວລາເລີ່ມຕົ້ນຂອງການກົດປຸ່ມຊ້ຳ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:99
msgid "Initial key repeat delay in milliseconds."
msgstr "ການໜ່ວງເວລາເລີ່ມຕົ້ນຂອງການກົດປຸ່ມຊ້ຳເປັນມິນລິວິນາທີ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:103
msgid "Remember NumLock state"
msgstr "ຈື່ສະຖານະ NumLock"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:104
msgid ""
"When set to true, GNOME will remember the state of the NumLock LED between "
"sessions."
msgstr "ເມື່ອຕັ້ງເປັນ true, GNOME ຈະຈື່ສະຖານະຂອງໄຟ NumLock ລະຫວ່າງເຊສຊັນ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:108
msgid "NumLock state"
msgstr "ສະຖານະ NumLock"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:109
msgid "The remembered state of the NumLock LED."
msgstr "ສະຖານະທີ່ຈື່ໄວ້ຂອງໄຟ NumLock."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:115
msgid "Mouse button orientation"
msgstr "ທິດທາງປຸ່ມເມົ້າສ໌"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:116
msgid "Swap left and right mouse buttons for left-handed mice."
msgstr "ສັບປ່ຽນປຸ່ມເມົ້າສ໌ຊ້າຍ ແລະ ຂວາສຳລັບຜູ້ທີ່ຖະໜັດຊ້າຍ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:121
msgid ""
"Pointer speed for mice. Accepted values are in the [-1..1] range (from "
"“unaccelerated” to “fast”). A value of 0 is the system default."
msgstr "ຄວາມໄວຕົວຊີ້ສຳລັບເມົ້າສ໌. ຄ່າທີ່ຍອມຮັບໄດ້ຢູ່ໃນຊ່ວງ [-1..1] (ຈາກ “ບໍ່ເລັ່ງ” ຫາ “ໄວ”). ຄ່າ 0 ແມ່ນຄ່າເລີ່ມຕົ້ນຂອງລະບົບ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:127
msgid "Set this to TRUE to enable natural (reverse) scrolling for mice."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອເປີດໃຊ້ການເລື່ອນແບບທຳມະຊາດ (ປີ້ນກັບ) ສຳລັບເມົ້າສ໌."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:132
msgid ""
"Acceleration profile used for connected mice. The acceleration profile can "
"be set to either default (“default”) which uses the default acceleration "
"profile for each device, flat (“flat”), which accelerates by a device "
"specific constant factor derived from the configured pointer speed, or "
"adaptive (“adaptive”) which adapts the acceleration depending on the mouse "
"movement. If a mouse doesn’t support the configured profile, “default” will "
"be used."
msgstr "ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວທີ່ໃຊ້ສຳລັບເມົ້າສ໌ທີ່ເຊື່ອມຕໍ່. ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວສາມາດຕັ້ງເປັນ “default” ເຊິ່ງໃຊ້ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວເລີ່ມຕົ້ນສຳລັບແຕ່ລະອຸປະກອນ, “flat” ເຊິ່ງເລັ່ງຄວາມໄວໂດຍປັດໄຈຄົງທີ່ຂອງອຸປະກອນທີ່ໄດ້ມາຈາກຄວາມໄວຕົວຊີ້ທີ່ກຳນົດ, ຫຼື “adaptive” ເຊິ່ງປັບການເລັ່ງຄວາມໄວຕາມການເຄື່ອນທີ່ຂອງເມົ້າສ໌. ຖ້າເມົ້າສ໌ບໍ່ຮອງຮັບໂປຣໄຟລ໌ທີ່ກຳນົດ, “default” ຈະຖືກໃຊ້."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:141
msgid "Double click time"
msgstr "ເວລາຄລິກສອງຄັ້ງ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:142
msgid "Length of a double click in milliseconds."
msgstr "ຄວາມຍາວຂອງການຄລິກສອງຄັ້ງເປັນມິນລິວິນາທີ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:146
msgid "Drag threshold"
msgstr "ຂອບເຂດການລາກ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:147
msgid "Distance before a drag is started."
msgstr "ໄລຍະຫ່າງກ່ອນທີ່ຈະເລີ່ມການລາກ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:153
msgid "Drawing tablet mapping"
msgstr "ການຈັບຄູ່ແທັບເລັດແຕ້ມຮູບ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:154
msgid ""
"EDID information of the output the tablet is mapped to. Must be in the "
"format [vendor, product, serial]. [\"\",\"\",\"\"] relies on automatic "
"mapping."
msgstr "ຂໍ້ມູນ EDID ຂອງຜົນຜະລິດທີ່ແທັບເລັດຖືກຈັບຄູ່ກັບ. ຕ້ອງຢູ່ໃນຮູບແບບ [vendor, product, serial]. [\"\",\"\",\"\"] ອີງໃສ່ການຈັບຄູ່ອັດຕະໂນມັດ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:158
msgid "Tablet mapping"
msgstr "ການຈັບຄູ່ແທັບເລັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:159
msgid "How input affects the pointer on the screen"
msgstr "ວິທີທີ່ການປ້ອນຂໍ້ມູນມີຜົນຕໍ່ຕົວຊີ້ເທິງໜ້າຈໍ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:163
msgid "Tablet area"
msgstr "ພື້ນທີ່ແທັບເລັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:164
msgid ""
"Dead area padding around the active area, in percentages. Respectively "
"applied to left,right,top and bottom sides."
msgstr "ພື້ນທີ່ຫວ່າງອ້ອມຮອບພື້ນທີ່ທີ່ໃຊ້ງານ, ເປັນເປີເຊັນ. ນຳໃຊ້ກັບດ້ານຊ້າຍ, ຂວາ, ເທິງ ແລະ ລຸ່ມ ຕາມລຳດັບ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:168
msgid "Tablet aspect ratio"
msgstr "ອັດຕາສ່ວນຂອງແທັບເລັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:169
msgid ""
"Enable this to restrict the tablet area to match the aspect ratio of the "
"output."
msgstr "ເປີດໃຊ້ຕົວເລືອກນີ້ເພື່ອຈຳກັດພື້ນທີ່ຂອງແທັບເລັດໃຫ້ກົງກັບອັດຕາສ່ວນຂອງຜົນຜະລິດ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:173
msgid "Tablet left-handed mode"
msgstr "ໂໝດຜູ້ຖະໜັດຊ້າຍຂອງແທັບເລັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:174
msgid ""
"Enable this to allow physically rotating the tablet for left-handed setups"
msgstr "ເປີດໃຊ້ຕົວເລືອກນີ້ເພື່ອອະນຸຍາດໃຫ້ໝຸນແທັບເລັດທາງກາຍະພາບສຳລັບການຕັ້ງຄ່າຂອງຜູ້ທີ່ຖະໜັດຊ້າຍ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:180
msgid "Stylus pressure curve"
msgstr "ເສັ້ນໂຄ້ງຄວາມດັນຂອງສະໄຕລັສ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:181
msgid ""
"Set this to x1, y1 and x2, y2 of the pressure curve applied to the stylus."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ x1, y1 ແລະ x2, y2 ຂອງເສັ້ນໂຄ້ງຄວາມດັນທີ່ນຳໃຊ້ກັບສະໄຕລັສ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:185
msgid "Stylus pressure range"
msgstr "ຊ່ວງຄວາມດັນຂອງສະໄຕລັສ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:186
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:196
msgid ""
"Set this to the percentage of the physical pressure range that should map to "
"the logical range."
msgstr "ຕັ້ງຄ່ານີ້ເປັນເປີເຊັນຂອງຊ່ວງຄວາມດັນທາງກາຍະພາບທີ່ຄວນຈະຈັບຄູ່ກັບຊ່ວງທາງເຫດຜົນ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:190
msgid "Eraser pressure curve"
msgstr "ເສັ້ນໂຄ້ງຄວາມດັນຂອງຢາງລຶບ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:191
msgid ""
"Set this to x1, y1 and x2, y2 of the pressure curve applied to the eraser."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ x1, y1 ແລະ x2, y2 ຂອງເສັ້ນໂຄ້ງຄວາມດັນທີ່ນຳໃຊ້ກັບຢາງລຶບ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:195
msgid "Eraser pressure range"
msgstr "ຊ່ວງຄວາມດັນຂອງຢາງລຶບ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:200
msgid "Button action"
msgstr "ການກະທຳຂອງປຸ່ມ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:201
msgid "Stylus button action, this button is located along the pen handle."
msgstr "ການກະທຳຂອງປຸ່ມສະໄຕລັສ, ປຸ່ມນີ້ຕັ້ງຢູ່ຕາມດ້າມປາກກາ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:205
msgid "Secondary button action"
msgstr "ການກະທຳຂອງປຸ່ມສຳຮອງ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:206
msgid ""
"Secondary stylus button action, this button is located along the pen handle "
"on some styli like the Grip Pen. Other styli like the Airbrush Pen or the "
"Inking Pen only have one button, this setting is ineffective on those."
msgstr "ການກະທຳຂອງປຸ່ມສະໄຕລັສສຳຮອງ, ປຸ່ມນີ້ຕັ້ງຢູ່ຕາມດ້າມປາກກາໃນບາງສະໄຕລັສເຊັ່ນ Grip Pen. ສະໄຕລັສອື່ນໆເຊັ່ນ Airbrush Pen ຫຼື Inking Pen ມີພຽງປຸ່ມດຽວ, ການຕັ້ງຄ່ານີ້ບໍ່ມີຜົນກັບພວກມັນ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:210
msgid "Tertiary button action"
msgstr "ການກະທຳຂອງປຸ່ມທີສາມ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:211
msgid ""
"Tertiary stylus button action, this button is located along the pen handle "
"on some styli like the 3D Pen. Other styli like the Grip Pen only have two "
"buttons, this setting is ineffective on those."
msgstr "ການກະທຳຂອງປຸ່ມສະໄຕລັສທີສາມ, ປຸ່ມນີ້ຕັ້ງຢູ່ຕາມດ້າມປາກກາໃນບາງສະໄຕລັສເຊັ່ນ 3D Pen. ສະໄຕລັສອື່ນໆເຊັ່ນ Grip Pen ມີພຽງສອງປຸ່ມ, ການຕັ້ງຄ່ານີ້ບໍ່ມີຜົນກັບພວກມັນ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:215
msgid "Key combination for the primary button"
msgstr "ການປະສົມປຸ່ມສຳລັບປຸ່ມຫຼັກ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:216
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:221
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:226
#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:238
msgid ""
"The keyboard shortcut generated when the button is pressed for custom "
"actions."
msgstr "ຄີລັດທີ່ຖືກສ້າງຂຶ້ນເມື່ອກົດປຸ່ມສຳລັບການກະທຳທີ່ກຳນົດເອງ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:220
msgid "Key combination for the secondary button"
msgstr "ການປະສົມປຸ່ມສຳລັບປຸ່ມສຳຮອງ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:225
msgid "Key combination for the tertiary button"
msgstr "ການປະສົມປຸ່ມສຳລັບປຸ່ມທີສາມ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:232
msgid "Pad button action type"
msgstr "ປະເພດການກະທຳຂອງປຸ່ມແພັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:233
msgid "The type of action triggered by the button being pressed."
msgstr "ປະເພດຂອງການກະທຳທີ່ຖືກກະຕຸ້ນໂດຍການກົດປຸ່ມ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:237
msgid "Key combination for the custom action"
msgstr "ການປະສົມປຸ່ມສຳລັບການກະທຳທີ່ກຳນົດເອງ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:244
msgid "Touchscreen output mapping"
msgstr "ການຈັບຄູ່ຜົນຜະລິດຂອງໜ້າຈໍສຳຜັດ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:245
msgid ""
"EDID information of the output the touchscreen is mapped to. Must be in the "
"format [vendor, product, serial]. [\"\",\"\",\"\"] relies on automatic "
"mapping."
msgstr "ຂໍ້ມູນ EDID ຂອງຜົນຜະລິດທີ່ໜ້າຈໍສຳຜັດຖືກຈັບຄູ່ກັບ. ຕ້ອງຢູ່ໃນຮູບແບບ [vendor, product, serial]. [\"\",\"\",\"\"] ອີງໃສ່ການຈັບຄູ່ອັດຕະໂນມັດ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:252
msgid "Mouse wheel emulation button. 0 to disable the feature."
msgstr "ປຸ່ມຈຳລອງລໍ້ເມົ້າສ໌. 0 ເພື່ອປິດຄຸນສົມບັດ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:256
msgid "Mouse wheel emulation button lock"
msgstr "ການລັອກປຸ່ມຈຳລອງລໍ້ເມົ້າສ໌"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:257
msgid ""
"Set this to TRUE to enable button locking for the wheel emulation button. If "
"enabled, the first click of the button enables scrolling, the second click "
"disables scrolling again."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອເປີດໃຊ້ການລັອກປຸ່ມສຳລັບປຸ່ມຈຳລອງລໍ້. ຖ້າເປີດໃຊ້, ການຄລິກຄັ້ງທຳອິດຂອງປຸ່ມຈະເປີດໃຊ້ການເລື່ອນ, ການຄລິກຄັ້ງທີສອງຈະປິດການເລື່ອນອີກຄັ້ງ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:262
msgid ""
"Acceleration profile used for the trackball. The acceleration profile can be "
"set to either default (“default”) which uses the default acceleration "
"profile, flat (“flat”), which accelerates by a device specific constant "
"factor derived from the configured speed, or adaptive (“adaptive”) which "
"adapts the acceleration depending on the movement. If the trackball doesn’t "
"support the configured profile, “default” will be used."
msgstr "ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວທີ່ໃຊ້ສຳລັບລູກກິ້ງ. ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວສາມາດຕັ້ງເປັນ “default” ເຊິ່ງໃຊ້ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວເລີ່ມຕົ້ນ, “flat” ເຊິ່ງເລັ່ງຄວາມໄວໂດຍປັດໄຈຄົງທີ່ຂອງອຸປະກອນທີ່ໄດ້ມາຈາກຄວາມໄວທີ່ກຳນົດ, ຫຼື “adaptive” ເຊິ່ງປັບການເລັ່ງຄວາມໄວຕາມການເຄື່ອນທີ່. ຖ້າລູກກິ້ງບໍ່ຮອງຮັບໂປຣໄຟລ໌ທີ່ກຳນົດ, “default” ຈະຖືກໃຊ້."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:274
msgid ""
"Pointer speed for pointing sticks. Accepted values are in the [-1..1] range "
"(from “unaccelerated” to “fast”). A value of 0 is the system default."
msgstr "ຄວາມໄວຕົວຊີ້ສຳລັບອຸປະກອນຊີ້. ຄ່າທີ່ຍອມຮັບໄດ້ຢູ່ໃນຊ່ວງ [-1..1] (ຈາກ “ບໍ່ເລັ່ງ” ຫາ “ໄວ”). ຄ່າ 0 ແມ່ນຄ່າເລີ່ມຕົ້ນຂອງລະບົບ."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:280
msgid ""
"Acceleration profile used for the pointing stick. The acceleration profile "
"can be set to either default (“default”) which uses the default acceleration "
"profile, flat (“flat”), which accelerates by a device specific constant "
"factor derived from the configured speed, or adaptive (“adaptive”) which "
"adapts the acceleration depending on the movement. If the pointing stick "
"doesn’t support the configured profile, “default” will be used."
msgstr "ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວທີ່ໃຊ້ສຳລັບອຸປະກອນຊີ້. ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວສາມາດຕັ້ງເປັນ “default” ເຊິ່ງໃຊ້ໂປຣໄຟລ໌ການເລັ່ງຄວາມໄວເລີ່ມຕົ້ນ, “flat” ເຊິ່ງເລັ່ງຄວາມໄວໂດຍປັດໄຈຄົງທີ່ຂອງອຸປະກອນທີ່ໄດ້ມາຈາກຄວາມໄວທີ່ກຳນົດ, ຫຼື “adaptive” ເຊິ່ງປັບການເລັ່ງຄວາມໄວຕາມການເຄື່ອນທີ່. ຖ້າອຸປະກອນຊີ້ບໍ່ຮອງຮັບໂປຣໄຟລ໌ທີ່ກຳນົດ, “default” ຈະຖືກໃຊ້."

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:284
msgid "Scrolling method"
msgstr "ວິທີການເລື່ອນ"

#: schemas/org.gnome.desktop.peripherals.gschema.xml.in:285
msgid ""
"Scrolling method used for pointing sticks. The scrolling method can be set "
"to either default (“default”) which uses the default method, none (“none”), "
"which disables scrolling, or middle-button (“on-button-down”) which enables "
"scrolling whilst the middle button is held down."
msgstr "ວິທີການເລື່ອນທີ່ໃຊ້ສຳລັບອຸປະກອນຊີ້. ວິທີການເລື່ອນສາມາດຕັ້ງເປັນ “default” ເຊິ່ງໃຊ້ວິທີເລີ່ມຕົ້ນ, “none” ເຊິ່ງປິດການເລື່ອນ, ຫຼື “middle-button” (“on-button-down”) ເຊິ່ງເປີດໃຊ້ການເລື່ອນໃນຂະນະທີ່ກົດປຸ່ມກາງຄ້າງໄວ້."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:6
msgid "Controls visibility of personal information"
msgstr "ຄວບຄຸມການເບິ່ງເຫັນຂໍ້ມູນສ່ວນຕົວ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:7
msgid ""
"If set to true, the system will make an effort to not divulge the user’s "
"identity on screen or on the network."
msgstr "ຖ້າຕັ້ງເປັນ true, ລະບົບຈະພະຍາຍາມບໍ່ເປີດເຜີຍຕົວຕົນຂອງຜູ້ໃຊ້ເທິງໜ້າຈໍ ຫຼື ໃນເຄືອຂ່າຍ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:12
msgid "Show full name in the user menu"
msgstr "ສະແດງຊື່ເຕັມໃນເມນູຜູ້ໃຊ້"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:13
msgid "Whether the users full name is shown in the user menu or not."
msgstr "ສະແດງວ່າຊື່ເຕັມຂອງຜູ້ໃຊ້ຈະຖືກສະແດງໃນເມນູຜູ້ໃຊ້ບໍ່."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:17
msgid "Whether to remove old files from the trash automatically"
msgstr "ສະແດງວ່າຈະລຶບໄຟລ໌ເກົ່າອອກຈາກຖັງຂີ້ເຫຍື້ອອັດຕະໂນມັດບໍ່"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:18
msgid ""
"If TRUE, automatically remove files from the trash when they are older than "
"“old-files-age” days."
msgstr "ຖ້າເປັນ TRUE, ຈະລຶບໄຟລ໌ອອກຈາກຖັງຂີ້ເຫຍື້ອອັດຕະໂນມັດເມື່ອມັນເກົ່າກວ່າ “old-files-age” ມື້."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:23
msgid "Whether to remove old temporary files automatically"
msgstr "ສະແດງວ່າຈະລຶບໄຟລ໌ຊົ່ວຄາວເກົ່າອັດຕະໂນມັດບໍ່"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:24
msgid ""
"If TRUE, automatically remove temporary files when they are older than “old-"
"files-age” days."
msgstr "ຖ້າເປັນ TRUE, ຈະລຶບໄຟລ໌ຊົ່ວຄາວອັດຕະໂນມັດເມື່ອມັນເກົ່າກວ່າ “old-files-age” ມື້."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:29
msgid "Number of days to keep trash and temporary files"
msgstr "ຈຳນວນມື້ທີ່ຈະເກັບໄຟລ໌ໃນຖັງຂີ້ເຫຍື້ອ ແລະ ໄຟລ໌ຊົ່ວຄາວ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:30
msgid "Consider trash and temporary files old after this many days."
msgstr "ໄຟລ໌ໃນຖັງຂີ້ເຫຍື້ອ ແລະ ໄຟລ໌ຊົ່ວຄາວຈະຖືກຖືວ່າເກົ່າຫຼັງຈາກຈຳນວນມື້ນີ້."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:35
msgid "Whether to remember recently used files"
msgstr "ສະແດງວ່າຈະຈື່ໄຟລ໌ທີ່ໃຊ້ຫຼ້າສຸດບໍ່"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:36
msgid "If FALSE, applications will not remember recently used files."
msgstr "ຖ້າເປັນ FALSE, ແອັບພລິເຄຊັນຈະບໍ່ຈື່ໄຟລ໌ທີ່ໃຊ້ຫຼ້າສຸດ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:41
msgid "Number of days to remember recently used files for"
msgstr "ຈຳນວນມື້ທີ່ຈະຈື່ໄຟລ໌ທີ່ໃຊ້ຫຼ້າສຸດ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:42
msgid ""
"Recently used files will be remembered for this many days. If set to 0, "
"recent files will not be remembered; if set to -1, they will be retained "
"indefinitely."
msgstr "ໄຟລ໌ທີ່ໃຊ້ຫຼ້າສຸດຈະຖືກຈື່ໄວ້ເປັນເວລາຈຳນວນມື້ນີ້. ຖ້າຕັ້ງເປັນ 0, ໄຟລ໌ທີ່ໃຊ້ຫຼ້າສຸດຈະບໍ່ຖືກຈື່; ຖ້າຕັ້ງເປັນ -1, ມັນຈະຖືກເກັບໄວ້ຕະຫຼອດໄປ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:48
msgid "Whether to remember application usage"
msgstr "ສະແດງວ່າຈະຈື່ການໃຊ້ງານແອັບພລິເຄຊັນບໍ່"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:49
msgid "If FALSE, application usage will not be monitored and recorded."
msgstr "ຖ້າເປັນ FALSE, ການໃຊ້ງານແອັບພລິເຄຊັນຈະບໍ່ຖືກຕິດຕາມ ແລະ ບັນທຶກ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:54
msgid "Send statistics when applications are removed or installed"
msgstr "ສົ່ງສະຖິຕິເມື່ອແອັບພລິເຄຊັນຖືກລຶບ ຫຼື ຕິດຕັ້ງ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:55
msgid ""
"If FALSE, no anonymous installation or removal information will be sent to "
"the vendor."
msgstr "ຖ້າເປັນ FALSE, ຈະບໍ່ມີຂໍ້ມູນການຕິດຕັ້ງ ຫຼື ການລຶບແບບບໍ່ລະບຸຊື່ຖືກສົ່ງໄປໃຫ້ຜູ້ຜະລິດ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:59
msgid "Send reports of technical problems to the vendor"
msgstr "ສົ່ງລາຍງານບັນຫາທາງເທັກນິກໄປໃຫ້ຜູ້ຜະລິດ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:60
msgid "If TRUE, anonymized reports will be sent automatically to the vendor."
msgstr "ຖ້າເປັນ TRUE, ລາຍງານທີ່ບໍ່ລະບຸຊື່ຈະຖືກສົ່ງໄປໃຫ້ຜູ້ຜະລິດອັດຕະໂນມັດ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:64
msgid "Don’t allow applications to access the microphone"
msgstr "ບໍ່ອະນຸຍາດໃຫ້ແອັບພລິເຄຊັນເຂົ້າເຖິງໄມໂຄຣໂຟນ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:65
msgid "If TRUE, applications should not use the microphone."
msgstr "ຖ້າເປັນ TRUE, ແອັບພລິເຄຊັນບໍ່ຄວນໃຊ້ໄມໂຄຣໂຟນ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:69
msgid "Don’t allow applications to access the camera"
msgstr "ບໍ່ອະນຸຍາດໃຫ້ແອັບພລິເຄຊັນເຂົ້າເຖິງກ້ອງ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:70
msgid "If TRUE, applications should not use the camera."
msgstr "ຖ້າເປັນ TRUE, ແອັບພລິເຄຊັນບໍ່ຄວນໃຊ້ກ້ອງ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:74
msgid "Don’t allow applications to output sound"
msgstr "ບໍ່ອະນຸຍາດໃຫ້ແອັບພລິເຄຊັນສົ່ງສຽງອອກ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:75
msgid "If TRUE, applications should not make sound."
msgstr "ຖ້າເປັນ TRUE, ແອັບພລິເຄຊັນບໍ່ຄວນສົ່ງສຽງ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:79
msgid "Whether to protect USB devices"
msgstr "ສະແດງວ່າຈະປົກປ້ອງອຸປະກອນ USB ບໍ່"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:80
msgid ""
"If the USBGuard service is present and this setting is enabled, USB devices "
"will be protected as configured in the usb-protection-level setting."
msgstr "ຖ້າມີບໍລິການ USBGuard ແລະ ການຕັ້ງຄ່ານີ້ເປີດຢູ່, ອຸປະກອນ USB ຈະຖືກປົກປ້ອງຕາມທີ່ກຳນົດໃນການຕັ້ງຄ່າ usb-protection-level."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:87
msgid "When USB devices should be rejected"
msgstr "ເວລາທີ່ອຸປະກອນ USB ຄວນຖືກປະຕິເສດ"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:88
msgid ""
"If set to “lockscreen”, only when the lock screen is present new USB devices "
"will be rejected; if set to “always”, all new USB devices will always be "
"rejected."
msgstr "ຖ້າຕັ້ງເປັນ “lockscreen”, ອຸປະກອນ USB ໃໝ່ຈະຖືກປະຕິເສດສະເພາະເມື່ອໜ້າຈໍລັອກຢູ່; ຖ້າຕັ້ງເປັນ “always”, ອຸປະກອນ USB ໃໝ່ທັງໝົດຈະຖືກປະຕິເສດຕະຫຼອດເວລາ."

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:95
msgid "Whether the privacy screen is enabled"
msgstr "ສະແດງວ່າໜ້າຈໍຄວາມເປັນສ່ວນຕົວເປີດຢູ່ບໍ່"

#: schemas/org.gnome.desktop.privacy.gschema.xml.in:96
msgid ""
"If the underlying hardware has privacy screen support and this setting is "
"enabled, the panels supporting this technology will be obscured from lateral "
"view."
msgstr "ຖ້າຮາດແວພື້ນຖານຮອງຮັບໜ້າຈໍຄວາມເປັນສ່ວນຕົວ ແລະ ການຕັ້ງຄ່ານີ້ເປີດຢູ່, ແຜງທີ່ຮອງຮັບເທັກໂນໂລຢີນີ້ຈະຖືກບັງຈາກມຸມມອງດ້ານຂ້າງ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:6
msgid "Enable restart/shutdown"
msgstr "ເປີດໃຊ້ການເປີດໃໝ່/ປິດເຄື່ອງ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:7
msgid "Allow shutdown and restart actions from the lock screen."
msgstr "ອະນຸຍາດການປິດເຄື່ອງ ແລະ ການເປີດໃໝ່ຈາກໜ້າຈໍລັອກ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:13
msgid "Activate when idle"
msgstr "ເປີດໃຊ້ງານເມື່ອບໍ່ມີການເຄື່ອນໄຫວ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:14
msgid ""
"Set this to TRUE to activate the screensaver when the session is idle. "
"DEPRECATED: This key is deprecated and ignored. Set "
"org.gnome.desktop.session idle-delay to 0 if you do not want to activate the "
"screensaver."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອເປີດໃຊ້ຕົວພັກໜ້າຈໍເມື່ອເຊສຊັນບໍ່ມີການເຄື່ອນໄຫວ. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ. ຕັ້ງ org.gnome.desktop.session idle-delay ເປັນ 0 ຖ້າທ່ານບໍ່ຕ້ອງການເປີດໃຊ້ຕົວພັກໜ້າຈໍ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:23
msgid "Lock on activation"
msgstr "ລັອກເມື່ອເປີດໃຊ້ງານ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:24
msgid "Set this to TRUE to lock the screen when the screensaver goes active."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອລັອກໜ້າຈໍເມື່ອຕົວພັກໜ້າຈໍເລີ່ມເຮັດວຽກ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:28
msgid "Time before locking"
msgstr "ເວລາກ່ອນທີ່ຈະລັອກ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:29
msgid ""
"The number of seconds after screensaver activation before locking the screen."
msgstr "ຈຳນວນວິນາທີຫຼັງຈາກຕົວພັກໜ້າຈໍເປີດໃຊ້ງານ ກ່ອນທີ່ຈະລັອກໜ້າຈໍ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:33
msgid "Show full name in the lock screen"
msgstr "ສະແດງຊື່ເຕັມໃນໜ້າຈໍລັອກ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:34
msgid ""
"Whether the user’s full name is shown in the lock screen or not. This only "
"affects the screen shield, the name is always shown in the unlock dialog."
msgstr "ສະແດງວ່າຊື່ເຕັມຂອງຜູ້ໃຊ້ຈະຖືກສະແດງໃນໜ້າຈໍລັອກບໍ່. ນີ້ມີຜົນສະເພາະກັບໜ້າຈໍປ້ອງກັນ, ຊື່ຈະຖືກສະແດງຢູ່ໃນກ່ອງໂຕ້ຕອບປົດລັອກສະເໝີ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:38
msgid "Allow embedding a keyboard into the window"
msgstr "ອະນຸຍາດໃຫ້ຝັງຄີບອດເຂົ້າໄປໃນໜ້າຕ່າງ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:39
msgid ""
"Set this to TRUE to allow embedding a keyboard into the window when trying "
"to unlock. The “keyboard_command” key must be set with the appropriate "
"command. DEPRECATED: This key is deprecated and ignored."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອອະນຸຍາດໃຫ້ຝັງຄີບອດເຂົ້າໄປໃນໜ້າຕ່າງເມື່ອພະຍາຍາມປົດລັອກ. ຄີ “keyboard_command” ຕ້ອງຖືກຕັ້ງດ້ວຍຄຳສັ່ງທີ່ເໝາະສົມ. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:47
msgid "Embedded keyboard command"
msgstr "ຄຳສັ່ງຄີບອດທີ່ຝັງໄວ້"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:48
msgid ""
"The command that will be run, if the “embedded_keyboard_enabled” key is set "
"to TRUE, to embed a keyboard widget into the window. This command should "
"implement an XEMBED plug interface and output a window XID on the standard "
"output. DEPRECATED: This key is deprecated and ignored."
msgstr "ຄຳສັ່ງທີ່ຈະຖືກເອີ້ນໃຊ້, ຖ້າຄີ “embedded_keyboard_enabled” ຖືກຕັ້ງເປັນ TRUE, ເພື່ອຝັງວິດເຈັດຄີບອດເຂົ້າໄປໃນໜ້າຕ່າງ. ຄຳສັ່ງນີ້ຄວນຈະປະຕິບັດຕາມອິນເຕີເຟດປລັກອິນ XEMBED ແລະ ສົ່ງອອກ XID ຂອງໜ້າຕ່າງໄປທີ່ຜົນຜະລິດມາດຕະຖານ. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:56
msgid "Allow logout"
msgstr "ອະນຸຍາດໃຫ້ອອກຈາກລະບົບ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:57
msgid ""
"Set this to TRUE to offer an option in the unlock dialog to allow logging "
"out after a delay. The delay is specified in the “logout_delay” key. "
"DEPRECATED: This key is deprecated and ignored."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອສະເໜີຕົວເລືອກໃນກ່ອງໂຕ້ຕອບປົດລັອກ ເພື່ອອະນຸຍາດໃຫ້ອອກຈາກລະບົບຫຼັງຈາກການໜ່ວງເວລາ. ການໜ່ວງເວລາຖືກກຳນົດໃນຄີ “logout_delay”. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:65
msgid "Time before logout option"
msgstr "ເວລາກ່ອນຈະມີຕົວເລືອກອອກຈາກລະບົບ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:66
msgid ""
"The number of seconds after the screensaver activation before a logout "
"option will appear in the unlock dialog. This key has effect only if the "
"“logout_enable” key is set to TRUE. DEPRECATED: This key is deprecated and "
"ignored"
msgstr "ຈຳນວນວິນາທີຫຼັງຈາກຕົວພັກໜ້າຈໍເປີດໃຊ້ງານ ກ່ອນທີ່ຕົວເລືອກອອກຈາກລະບົບຈະປາກົດໃນກ່ອງໂຕ້ຕອບປົດລັອກ. ຄີນີ້ມີຜົນສະເພາະຖ້າຄີ “logout_enable” ຖືກຕັ້ງເປັນ TRUE. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:74
msgid "Logout command"
msgstr "ຄຳສັ່ງອອກຈາກລະບົບ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:75
msgid ""
"The command to invoke when the logout button is clicked. This command should "
"simply log the user out without any interaction. This key has effect only if "
"the “logout_enable” key is set to TRUE. DEPRECATED: This key is deprecated "
"and ignored."
msgstr "ຄຳສັ່ງທີ່ຈະເອີ້ນໃຊ້ເມື່ອກົດປຸ່ມອອກຈາກລະບົບ. ຄຳສັ່ງນີ້ຄວນຈະອອກຈາກລະບົບຂອງຜູ້ໃຊ້ໂດຍບໍ່ມີການໂຕ້ຕອບໃດໆ. ຄີນີ້ມີຜົນສະເພາະຖ້າຄີ “logout_enable” ຖືກຕັ້ງເປັນ TRUE. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:83
msgid "Allow user switching"
msgstr "ອະນຸຍາດໃຫ້ສະຫຼັບຜູ້ໃຊ້"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:84
msgid ""
"Set this to TRUE to offer an option in the unlock dialog to switch to a "
"different user account."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອສະເໜີຕົວເລືອກໃນກ່ອງໂຕ້ຕອບປົດລັອກ ເພື່ອສະຫຼັບໄປບັນຊີຜູ້ໃຊ້ອື່ນ."

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:88
msgid "Allow the session status message to be displayed"
msgstr "ອະນຸຍາດໃຫ້ສະແດງຂໍ້ຄວາມສະຖານະຂອງເຊສຊັນ"

#: schemas/org.gnome.desktop.screensaver.gschema.xml.in:89
msgid ""
"Allow the session status message to be displayed when the screen is locked. "
"DEPRECATED: This key is deprecated and ignored."
msgstr "ອະນຸຍາດໃຫ້ສະແດງຂໍ້ຄວາມສະຖານະຂອງເຊສຊັນເມື່ອໜ້າຈໍຖືກລັອກ. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ."

#: schemas/org.gnome.desktop.screen-time-limits.gschema.xml.in:9
msgid "Enable screen time history"
msgstr "ເປີດໃຊ້ປະຫວັດເວລາໜ້າຈໍ"

#: schemas/org.gnome.desktop.screen-time-limits.gschema.xml.in:10
msgid ""
"Enable basic screen time functionality, recording usage data for viewing "
"history."
msgstr "ເປີດໃຊ້ງານຟັງຊັນເວລາໜ້າຈໍພື້ນຖານ, ບັນທຶກຂໍ້ມູນການໃຊ້ງານເພື່ອເບິ່ງປະຫວັດ."

#: schemas/org.gnome.desktop.screen-time-limits.gschema.xml.in:17
msgid "Enable daily screen time limit"
msgstr "ເປີດໃຊ້ການຈຳກັດເວລາໜ້າຈໍປະຈຳວັນ"

#: schemas/org.gnome.desktop.screen-time-limits.gschema.xml.in:18
msgid ""
"Enable imposing a screen time limit on the user, as set in daily-limit-"
"seconds."
msgstr "ເປີດໃຊ້ການບັງຄັບການຈຳກັດເວລາໜ້າຈໍຂອງຜູ້ໃຊ້, ຕາມທີ່ຕັ້ງໄວ້ໃນ daily-limit-seconds."

#: schemas/org.gnome.desktop.screen-time-limits.gschema.xml.in:23
msgid "Daily screen time limit"
msgstr "ການຈຳກັດເວລາໜ້າຈໍປະຈຳວັນ"

#: schemas/org.gnome.desktop.screen-time-limits.gschema.xml.in:24
msgid ""
"The limit on the amount of daily screen time the user is allowed, in seconds."
msgstr "ຂີດຈຳກັດຂອງເວລາໜ້າຈໍປະຈຳວັນທີ່ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດ, ເປັນວິນາທີ."

#: schemas/org.gnome.desktop.screen-time-limits.gschema.xml.in:30
msgid "Grayscale once limit is reached"
msgstr "ປ່ຽນເປັນສີເທົາເມື່ອຮອດຂີດຈຳກັດ"

#: schemas/org.gnome.desktop.screen-time-limits.gschema.xml.in:31
msgid ""
"Whether to make the screen grayscale once the user’s screen time limit is "
"reached."
msgstr "ສະແດງວ່າຈະເຮັດໃຫ້ໜ້າຈໍເປັນສີເທົາບໍ່ ເມື່ອເວລາໜ້າຈໍຂອງຜູ້ໃຊ້ຮອດຂີດຈຳກັດ."

#: schemas/org.gnome.desktop.search-providers.gschema.xml.in:7
msgid "Disable all external search providers"
msgstr "ປິດໃຊ້ງານຜູ້ໃຫ້ບໍລິການຄົ້ນຫາພາຍນອກທັງໝົດ"

#: schemas/org.gnome.desktop.search-providers.gschema.xml.in:8
msgid ""
"Set to true to disable all external search provider programs, whether or not "
"they are independently disabled or enabled. External search providers are "
"installed by applications in $XDG_DATA_DIR/gnome-shell/search-providers."
msgstr "ຕັ້ງເປັນ true ເພື່ອປິດໃຊ້ງານໂປຣແກຣມຜູ້ໃຫ້ບໍລິການຄົ້ນຫາພາຍນອກທັງໝົດ, ບໍ່ວ່າພວກມັນຈະຖືກປິດ ຫຼື ເປີດໃຊ້ງານໂດຍອິສະລະກໍຕາມ. ຜູ້ໃຫ້ບໍລິການຄົ້ນຫາພາຍນອກຖືກຕິດຕັ້ງໂດຍແອັບພລິເຄຊັນໃນ $XDG_DATA_DIR/gnome-shell/search-providers."

#: schemas/org.gnome.desktop.search-providers.gschema.xml.in:18
msgid ""
"List of desktop file IDs for which the associated default-enabled search "
"provider should be disabled"
msgstr "ລາຍຊື່ ID ໄຟລ໌ desktop ທີ່ຜູ້ໃຫ້ບໍລິການຄົ້ນຫາທີ່ເປີດໃຊ້ໂດຍຄ່າເລີ່ມຕົ້ນທີ່ກ່ຽວຂ້ອງຄວນຖືກປິດ"

#: schemas/org.gnome.desktop.search-providers.gschema.xml.in:22
msgid ""
"Results for applications contained in this list will not be displayed when "
"searching."
msgstr "ຜົນການຄົ້ນຫາສຳລັບແອັບພລິເຄຊັນທີ່ຢູ່ໃນລາຍຊື່ນີ້ຈະບໍ່ຖືກສະແດງເມື່ອຄົ້ນຫາ."

#: schemas/org.gnome.desktop.search-providers.gschema.xml.in:30
msgid ""
"List of desktop file IDs for which the associated default-disabled search "
"provider should be enabled"
msgstr "ລາຍຊື່ ID ໄຟລ໌ desktop ທີ່ຜູ້ໃຫ້ບໍລິການຄົ້ນຫາທີ່ປິດໃຊ້ໂດຍຄ່າເລີ່ມຕົ້ນທີ່ກ່ຽວຂ້ອງຄວນຖືກເປີດ"

#: schemas/org.gnome.desktop.search-providers.gschema.xml.in:34
msgid ""
"Results for applications contained in this list will be displayed when "
"searching."
msgstr "ຜົນການຄົ້ນຫາສຳລັບແອັບພລິເຄຊັນທີ່ຢູ່ໃນລາຍຊື່ນີ້ຈະຖືກສະແດງເມື່ອຄົ້ນຫາ."

#: schemas/org.gnome.desktop.search-providers.gschema.xml.in:42
msgid "List of desktop file IDs for search providers sort order"
msgstr "ລາຍຊື່ ID ໄຟລ໌ desktop ສໍາລັບລໍາດັບການຈັດລຽງຂອງຜູ້ໃຫ້ບໍລິການຄົ້ນຫາ"

#: schemas/org.gnome.desktop.search-providers.gschema.xml.in:43
msgid ""
"Results for applications contained in this list will be displayed in the "
"specified order. Results for applications not specified in this list will be "
"displayed last, sorted alphabetically."
msgstr "ຜົນການຄົ້ນຫາສໍາລັບແອັບພລິເຄຊັນທີ່ຢູ່ໃນລາຍການນີ້ຈະຖືກສະແດງຕາມລໍາດັບທີ່ກໍານົດໄວ້. ຜົນການຄົ້ນຫາສໍາລັບແອັບພລິເຄຊັນທີ່ບໍ່ໄດ້ລະບຸໃນລາຍການນີ້ຈະຖືກສະແດງຢູ່ສຸດທ້າຍ, ຈັດຮຽງຕາມຕົວອັກສອນ."

#: schemas/org.gnome.desktop.session.gschema.xml.in:6
msgid "Time before session is considered idle"
msgstr "ເວລາກ່ອນທີ່ເຊສຊັນຈະຖືກຖືວ່າບໍ່ມີການເຄື່ອນໄຫວ"

#: schemas/org.gnome.desktop.session.gschema.xml.in:7
msgid ""
"The number of seconds of inactivity before the session is considered idle."
msgstr "ຈຳນວນວິນາທີຂອງການບໍ່ມີການເຄື່ອນໄຫວກ່ອນທີ່ເຊສຊັນຈະຖືກຖືວ່າບໍ່ມີການເຄື່ອນໄຫວ."

#: schemas/org.gnome.desktop.session.gschema.xml.in:11
msgid "Session type"
msgstr "ປະເພດເຊສຊັນ"

#: schemas/org.gnome.desktop.session.gschema.xml.in:12
msgid "The name of the session to use. Known value is “gnome”."
msgstr "ຊື່ຂອງເຊສຊັນທີ່ຈະໃຊ້. ຄ່າທີ່ຮູ້ຈັກແມ່ນ “gnome”."

#: schemas/org.gnome.desktop.sound.gschema.xml.in:6
msgid "Sounds for events"
msgstr "ສຽງສຳລັບເຫດການ"

#: schemas/org.gnome.desktop.sound.gschema.xml.in:7
msgid "Whether to play sounds on user events."
msgstr "ສະແດງວ່າຈະເປີດສຽງໃນເຫດການຂອງຜູ້ໃຊ້ບໍ່."

#: schemas/org.gnome.desktop.sound.gschema.xml.in:11
msgid "Sound theme name"
msgstr "ຊື່ຊຸດສຽງ"

#: schemas/org.gnome.desktop.sound.gschema.xml.in:12
msgid "The XDG sound theme to use for event sounds."
msgstr "ຊຸດສຽງ XDG ທີ່ຈະໃຊ້ສຳລັບສຽງເຫດການ."

