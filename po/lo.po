#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:268
msgid "Move window to the next monitor above"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍພາບຖັດໄປທາງເທິງ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:272
msgid "Move window to the next monitor below"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍພາບຖັດໄປທາງລຸ່ມ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:276
msgid "Raise window if covered, otherwise lower it"
msgstr "ຍົກໜ້າຕ່າງຂຶ້ນຖ້າຖືກບັງ, ຖ້າບໍ່ດັ່ງນັ້ນກໍ່ຫຼຸດລົງ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:280
msgid "Raise window above other windows"
msgstr "ຍົກໜ້າຕ່າງຂຶ້ນເໜືອໜ້າຕ່າງອື່ນ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:284
msgid "Lower window below other windows"
msgstr "ຫຼຸດໜ້າຕ່າງລົງໃຕ້ໜ້າຕ່າງອື່ນ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:288
msgid "Maximize window vertically"
msgstr "ຂະຫຍາຍໜ້າຕ່າງຕາມລວງຕັ້ງ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:292
msgid "Maximize window horizontally"
msgstr "ຂະຫຍາຍໜ້າຕ່າງຕາມລວງນອນ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:296
msgid "Move window to top left corner"
msgstr "ຍ້າຍໜ້າຕ່າງໄປມຸມເທິງຊ້າຍ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:300
msgid "Move window to top right corner"
msgstr "ຍ້າຍໜ້າຕ່າງໄປມຸມເທິງຂວາ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:304
msgid "Move window to bottom left corner"
msgstr "ຍ້າຍໜ້າຕ່າງໄປມຸມລຸ່ມຊ້າຍ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:308
msgid "Move window to bottom right corner"
msgstr "ຍ້າຍໜ້າຕ່າງໄປມຸມລຸ່ມຂວາ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:312
msgid "Move window to top edge of screen"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຂອບເທິງຂອງໜ້າຈໍ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:316
msgid "Move window to bottom edge of screen"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຂອບລຸ່ມຂອງໜ້າຈໍ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:320
msgid "Move window to right side of screen"
msgstr "ຍ້າຍໜ້າຕ່າງໄປດ້ານຂວາຂອງໜ້າຈໍ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:324
msgid "Move window to left side of screen"
msgstr "ຍ້າຍໜ້າຕ່າງໄປດ້ານຊ້າຍຂອງໜ້າຈໍ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:328
msgid "Move window to center of screen"
msgstr "ຍ້າຍໜ້າຕ່າງໄປໃຈກາງຂອງໜ້າຈໍ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:332
msgid "Switch input source"
msgstr "ສະຫຼັບແຫຼ່ງປ້ອນຂໍ້ມູນ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:333
msgid "Binding to select the next input source"
msgstr "ການຜູກປຸ່ມເພື່ອເລືອກແຫຼ່ງປ້ອນຂໍ້ມູນຖັດໄປ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:337
msgid "Switch input source backward"
msgstr "ສະຫຼັບແຫຼ່ງປ້ອນຂໍ້ມູນກັບຄືນ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:338
msgid "Binding to select the previous input source"
msgstr "ການຜູກປຸ່ມເພື່ອເລືອກແຫຼ່ງປ້ອນຂໍ້ມູນກ່ອນໜ້າ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:342
msgid "Toggle window to be always on top"
msgstr "ສະຫຼັບໃຫ້ໜ້າຕ່າງຢູ່ເທິງສຸດສະເໝີ"

#: schemas/org.gnome.desktop.wm.keybindings.gschema.xml.in:343
msgid "Set or unset window to appear always on top"
msgstr "ຕັ້ງ ຫຼື ຍົກເລີກການຕັ້ງຄ່າໃຫ້ໜ້າຕ່າງປາກົດຢູ່ເທິງສຸດສະເໝີ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:8
msgid "Modifier to use for modified window click actions"
msgstr "ປຸ່ມໂມດິໄຟເອີທີ່ຈະໃຊ້ສໍາລັບການກະທໍາຄລິກໜ້າຕ່າງທີ່ຖືກດັດແປງ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:9
msgid ""
"Clicking a window while holding down this modifier key will move the window "
"(left click), resize the window (middle click), or show the window menu "
"(right click). The middle and right click operations may be swapped using "
"the “resize-with-right-button” key. Modifier is expressed as “<Alt>” or "
"“<Super>” for example."
msgstr "ການຄລິກໜ້າຕ່າງໃນຂະນະທີ່ກົດປຸ່ມໂມດິໄຟເອີນີ້ຄ້າງໄວ້ຈະຍ້າຍໜ້າຕ່າງ (ຄລິກຊ້າຍ), ປັບຂະໜາດໜ້າຕ່າງ (ຄລິກກາງ), ຫຼື ສະແດງເມນູໜ້າຕ່າງ (ຄລິກຂວາ). ການດຳເນີນການຄລິກກາງ ແລະ ຄລິກຂວາອາດຈະຖືກສັບປ່ຽນກັນໂດຍໃຊ້ຄີ “resize-with-right-button”. ໂມດິໄຟເອີສະແດງອອກເປັນ “<Alt>” ຫຼື “<Super>” ເປັນຕົ້ນ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:19
msgid "Whether to resize with the right button"
msgstr "ສະແດງວ່າຈະປັບຂະຫນາດດ້ວຍປຸ່ມຂວາບໍ່"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:20
msgid ""
"Set this to true to resize with the right button and show a menu with the "
"middle button while holding down the key given in “mouse-button-modifier”; "
"set it to false to make it work the opposite way around."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ true ເພື່ອປັບຂະໜາດດ້ວຍປຸ່ມຂວາ ແລະ ສະແດງເມນູດ້ວຍປຸ່ມກາງໃນຂະນະທີ່ກົດປຸ່ມທີ່ໃຫ້ໄວ້ໃນ “mouse-button-modifier” ຄ້າງໄວ້; ຕັ້ງເປັນ false ເພື່ອໃຫ້ມັນເຮັດວຽກກົງກັນຂ້າມ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:29
msgid "Arrangement of buttons on the titlebar"
msgstr "ການຈັດວາງປຸ່ມເທິງແຖບຫົວຂໍ້"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:30
msgid ""
"Arrangement of buttons on the titlebar. The value should be a string, such "
"as “menu:minimize,maximize,spacer,close”; the colon separates the left "
"corner of the window from the right corner, and the button names are comma-"
"separated. Duplicate buttons are not allowed. Unknown button names are "
"silently ignored so that buttons can be added in future metacity versions "
"without breaking older versions. A special spacer tag can be used to insert "
"some space between two adjacent buttons."
msgstr "ການຈັດວາງປຸ່ມເທິງແຖບຫົວຂໍ້. ຄ່າຄວນເປັນສະຕຣິງ, ເຊັ່ນ “menu:minimize,maximize,spacer,close”; ເຄື່ອງໝາຍຈໍ້າສອງເມັດແຍກມຸມຊ້າຍຂອງໜ້າຕ່າງອອກຈາກມຸມຂວາ, ແລະ ຊື່ປຸ່ມຖືກແຍກດ້ວຍເຄື່ອງໝາຍຈຸດ. ບໍ່ອະນຸຍາດໃຫ້ມີປຸ່ມຊ້ຳກັນ. ຊື່ປຸ່ມທີ່ບໍ່ຮູ້ຈັກຈະຖືກບໍ່ສົນໃຈຢ່າງງຽບໆ ເພື່ອໃຫ້ສາມາດເພີ່ມປຸ່ມໃນເວີຊັນ metacity ໃນອະນາຄົດໄດ້ໂດຍບໍ່ເຮັດໃຫ້ເວີຊັນເກົ່າເສຍຫາຍ. ສາມາດໃຊ້ແທັກພິເສດ spacer ເພື່ອໃສ່ຊ່ອງຫວ່າງລະຫວ່າງປຸ່ມສອງປຸ່ມທີ່ຢູ່ຕິດກັນ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:43
msgid "Window focus mode"
msgstr "ໂໝດໂຟກັສໜ້າຕ່າງ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:44
msgid ""
"The window focus mode indicates how windows are activated. It has three "
"possible values; “click” means windows must be clicked in order to focus "
"them, “sloppy” means windows are focused when the mouse enters the window, "
"and “mouse” means windows are focused when the mouse enters the window and "
"unfocused when the mouse leaves the window."
msgstr "ໂໝດໂຟກັສໜ້າຕ່າງບົ່ງບອກວິທີທີ່ໜ້າຕ່າງຖືກເປີດໃຊ້ງານ. ມັນມີສາມຄ່າທີ່ເປັນໄປໄດ້; “click” ໝາຍຄວາມວ່າຕ້ອງຄລິກໜ້າຕ່າງເພື່ອໂຟກັສ, “sloppy” ໝາຍຄວາມວ່າໜ້າຕ່າງຈະຖືກໂຟກັສເມື່ອເມົ້າສ໌ເຂົ້າໄປໃນໜ້າຕ່າງ, ແລະ “mouse” ໝາຍຄວາມວ່າໜ້າຕ່າງຈະຖືກໂຟກັສເມື່ອເມົ້າສ໌ເຂົ້າໄປໃນໜ້າຕ່າງ ແລະ ບໍ່ຖືກໂຟກັສເມື່ອເມົ້າສ໌ອອກຈາກໜ້າຕ່າງ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:55
msgid "Control how new windows get focus"
msgstr "ຄວບຄຸມວິທີທີ່ໜ້າຕ່າງໃໝ່ໄດ້ຮັບການໂຟກັສ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:56
msgid ""
"This option provides additional control over how newly created windows get "
"focus. It has two possible values; “smart” applies the user’s normal focus "
"mode, and “strict” results in new windows not being given focus "
"automatically."
msgstr "ຕົວເລືອກນີ້ໃຫ້ການຄວບຄຸມເພີ່ມເຕີມກ່ຽວກັບວິທີທີ່ໜ້າຕ່າງທີ່ສ້າງຂຶ້ນໃໝ່ໄດ້ຮັບການໂຟກັສ. ມັນມີສອງຄ່າທີ່ເປັນໄປໄດ້; “smart” ຈະນຳໃຊ້ໂໝດໂຟກັສປົກກະຕິຂອງຜູ້ໃຊ້, ແລະ “strict” ຈະເຮັດໃຫ້ໜ້າຕ່າງໃໝ່ບໍ່ໄດ້ຮັບການໂຟກັສໂດຍອັດຕະໂນມັດ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:65
msgid "Whether windows should be raised when their client area is clicked"
msgstr "ສະແດງວ່າໜ້າຕ່າງຄວນຖືກຍົກຂຶ້ນບໍ່ເມື່ອພື້ນທີ່ຂອງມັນຖືກຄລິກ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:68
msgid ""
"The default, true, indicates that a window will be raised whenever its "
"client area or its frame is clicked. Setting this to false means that a "
"window will not be raised if it is clicked on the client area. To raise it, "
"one can click anywhere in the window’s frame, or Super-click on any part of "
"the window. This mode is useful if one uses many overlapping windows."
msgstr "ຄ່າເລີ່ມຕົ້ນ, true, ບົ່ງບອກວ່າໜ້າຕ່າງຈະຖືກຍົກຂຶ້ນທຸກຄັ້ງທີ່ພື້ນທີ່ຂອງມັນ ຫຼື ຂອບຂອງມັນຖືກຄລິກ. ການຕັ້ງຄ່ານີ້ເປັນ false ໝາຍຄວາມວ່າໜ້າຕ່າງຈະບໍ່ຖືກຍົກຂຶ້ນຖ້າຖືກຄລິກໃສ່ພື້ນທີ່ຂອງມັນ. ເພື່ອຍົກມັນຂຶ້ນ, ສາມາດຄລິກທີ່ໃດກໍໄດ້ໃນຂອບຂອງໜ້າຕ່າງ, ຫຼື ກົດ Super-ຄລິກໃສ່ສ່ວນໃດກໍໄດ້ຂອງໜ້າຕ່າງ. ໂໝດນີ້ມີປະໂຫຍດຖ້າໃຊ້ໜ້າຕ່າງທີ່ຊ້ອນກັນຫຼາຍໜ້າຕ່າງ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:82
msgid "Action on title bar double-click"
msgstr "ການກະທຳເມື່ອຄລິກສອງຄັ້ງເທິງແຖບຫົວຂໍ້"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:83
msgid ""
"This option determines the effects of double-clicking on the title bar. "
"Current valid options are “toggle-maximize” which will maximize/unmaximize "
"the window, “toggle-maximize-horizontally” and “toggle-maximize-vertically” "
"which will maximize/unmaximize the window in that direction only, “minimize” "
"which will minimize the window, “menu” which will display the window menu, "
"“lower” which will put the window behind all the others, and “none” which "
"will not do anything."
msgstr "ຕົວເລືອກນີ້ກຳນົດຜົນຂອງການຄລິກສອງຄັ້ງເທິງແຖບຫົວຂໍ້. ຕົວເລືອກທີ່ຖືກຕ້ອງໃນປັດຈຸບັນແມ່ນ “toggle-maximize” ເຊິ່ງຈະຂະຫຍາຍ/ຫຍໍ້ໜ້າຕ່າງ, “toggle-maximize-horizontally” ແລະ “toggle-maximize-vertically” ເຊິ່ງຈະຂະຫຍາຍ/ຫຍໍ້ໜ້າຕ່າງໃນທິດທາງນັ້ນເທົ່ານັ້ນ, “minimize” ເຊິ່ງຈະຫຍໍ້ໜ້າຕ່າງ, “menu” ເຊິ່ງຈະສະແດງເມນູໜ້າຕ່າງ, “lower” ເຊິ່ງຈະວາງໜ້າຕ່າງໄວ້ທາງຫຼັງທັງໝົດ, ແລະ “none” ເຊິ່ງຈະບໍ່ເຮັດຫຍັງເລີຍ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:105
msgid "Action on title bar middle-click"
msgstr "ການກະທຳເມື່ອຄລິກກາງເທິງແຖບຫົວຂໍ້"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:106
msgid ""
"This option determines the effects of middle-clicking on the title bar. "
"Current valid options are “toggle-maximize” which will maximize/unmaximize "
"the window, “toggle-maximize-horizontally” and “toggle-maximize-vertically” "
"which will maximize/unmaximize the window in that direction only, “minimize” "
"which will minimize the window, “menu” which will display the window menu, "
"“lower” which will put the window behind all the others, and “none” which "
"will not do anything."
msgstr "ຕົວເລືອກນີ້ກຳນົດຜົນຂອງການຄລິກກາງເທິງແຖບຫົວຂໍ້. ຕົວເລືອກທີ່ຖືກຕ້ອງໃນປັດຈຸບັນແມ່ນ “toggle-maximize” ເຊິ່ງຈະຂະຫຍາຍ/ຫຍໍ້ໜ້າຕ່າງ, “toggle-maximize-horizontally” ແລະ “toggle-maximize-vertically” ເຊິ່ງຈະຂະຫຍາຍ/ຫຍໍ້ໜ້າຕ່າງໃນທິດທາງນັ້ນເທົ່ານັ້ນ, “minimize” ເຊິ່ງຈະຫຍໍ້ໜ້າຕ່າງ, “menu” ເຊິ່ງຈະສະແດງເມນູໜ້າຕ່າງ, “lower” ເຊິ່ງຈະວາງໜ້າຕ່າງໄວ້ທາງຫຼັງທັງໝົດ, ແລະ “none” ເຊິ່ງຈະບໍ່ເຮັດຫຍັງເລີຍ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:129
msgid "Action on title bar right-click"
msgstr "ການກະທຳເມື່ອຄລິກຂວາເທິງແຖບຫົວຂໍ້"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:130
msgid ""
"This option determines the effects of right-clicking on the title bar. "
"Current valid options are “toggle-maximize” which will maximize/unmaximize "
"the window, “toggle-maximize-horizontally” and “toggle-maximize-vertically” "
"which will maximize/unmaximize the window in that direction only, “minimize” "
"which will minimize the window, “menu” which will display the window menu, "
"“lower” which will put the window behind all the others, and “none” which "
"will not do anything."
msgstr "ຕົວເລືອກນີ້ກຳນົດຜົນຂອງການຄລິກຂວາເທິງແຖບຫົວຂໍ້. ຕົວເລືອກທີ່ຖືກຕ້ອງໃນປັດຈຸບັນແມ່ນ “toggle-maximize” ເຊິ່ງຈະຂະຫຍາຍ/ຫຍໍ້ໜ້າຕ່າງ, “toggle-maximize-horizontally” ແລະ “toggle-maximize-vertically” ເຊິ່ງຈະຂະຫຍາຍ/ຫຍໍ້ໜ້າຕ່າງໃນທິດທາງນັ້ນເທົ່ານັ້ນ, “minimize” ເຊິ່ງຈະຫຍໍ້ໜ້າຕ່າງ, “menu” ເຊິ່ງຈະສະແດງເມນູໜ້າຕ່າງ, “lower” ເຊິ່ງຈະວາງໜ້າຕ່າງໄວ້ທາງຫຼັງທັງໝົດ, ແລະ “none” ເຊິ່ງຈະບໍ່ເຮັດຫຍັງເລີຍ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:152
msgid "Automatically raises the focused window"
msgstr "ຍົກໜ້າຕ່າງທີ່ຖືກໂຟກັສຂຶ້ນອັດຕະໂນມັດ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:153
msgid ""
"If set to true, and the focus mode is either “sloppy” or “mouse” then the "
"focused window will be automatically raised after a delay specified by the "
"auto-raise-delay key. This is not related to clicking on a window to raise "
"it, nor to entering a window during drag-and-drop."
msgstr "ຖ້າຕັ້ງເປັນ true, ແລະ ໂໝດໂຟກັສແມ່ນ “sloppy” ຫຼື “mouse” ແລ້ວ ໜ້າຕ່າງທີ່ຖືກໂຟກັສຈະຖືກຍົກຂຶ້ນອັດຕະໂນມັດຫຼັງຈາກການໜ່ວງເວລາທີ່ກຳນົດໂດຍຄີ auto-raise-delay. ນີ້ບໍ່ກ່ຽວຂ້ອງກັບການຄລິກໃສ່ໜ້າຕ່າງເພື່ອຍົກມັນຂຶ້ນ, ຫຼື ການເຂົ້າໄປໃນໜ້າຕ່າງໃນລະຫວ່າງການລາກແລະວາງ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:163
msgid "Delay in milliseconds for the auto raise option"
msgstr "ການໜ່ວງເວລາເປັນມິນລິວິນາທີສຳລັບຕົວເລືອກຍົກຂຶ້ນອັດຕະໂນມັດ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:164
msgid ""
"The time delay before raising a window if auto-raise is set to true. The "
"delay is given in thousandths of a second."
msgstr "ການໜ່ວງເວລາກ່ອນທີ່ຈະຍົກໜ້າຕ່າງຂຶ້ນຖ້າ auto-raise ຖືກຕັ້ງເປັນ true. ການໜ່ວງເວລາແມ່ນໃຫ້ເປັນພັນສ່ວນຂອງວິນາທີ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:171
msgid "Current theme"
msgstr "ຊຸດຮູບແບບປັດຈຸບັນ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:172
msgid ""
"The theme determines the appearance of window borders, titlebar, and so "
"forth. DEPRECATED: This key is deprecated and ignored."
msgstr "ຊຸດຮູບແບບກຳນົດຮູບລັກຂອງຂອບໜ້າຕ່າງ, ແຖບຫົວຂໍ້, ແລະອື່ນໆ. ບໍ່ຖືກໃຊ້ແລ້ວ: ຄີນີ້ບໍ່ຖືກໃຊ້ ແລະ ຈະຖືກບໍ່ສົນໃຈ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:181
msgid "Use standard system font in window titles"
msgstr "ໃຊ້ຟອນຕ໌ລະບົບມາດຕະຖານໃນຫົວຂໍ້ໜ້າຕ່າງ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:182
msgid ""
"If true, ignore the titlebar-font option, and use the standard application "
"font for window titles."
msgstr "ຖ້າເປັນ true, ຈະບໍ່ສົນໃຈຕົວເລືອກ titlebar-font, ແລະ ຈະໃຊ້ຟອນຕ໌ແອັບພລິເຄຊັນມາດຕະຖານສຳລັບຫົວຂໍ້ໜ້າຕ່າງ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:189
msgid "Window title font"
msgstr "ຟອນຕ໌ຫົວຂໍ້ໜ້າຕ່າງ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:190
msgid ""
"A font description string describing a font for window titlebars. The size "
"from the description will only be used if the titlebar-font-size option is "
"set to 0. Also, this option is disabled if the titlebar-uses-desktop-font "
"option is set to true."
msgstr "ສະຕຣິງຄຳອະທິບາຍຟອນຕ໌ທີ່ອະທິບາຍຟອນຕ໌ສຳລັບແຖບຫົວຂໍ້ໜ້າຕ່າງ. ຂະໜາດຈາກຄຳອະທິບາຍຈະຖືກໃຊ້ສະເພາະຖ້າຕົວເລືອກ titlebar-font-size ຖືກຕັ້ງເປັນ 0. ນອກຈາກນີ້, ຕົວເລືອກນີ້ຈະຖືກປິດຖ້າຕົວເລືອກ titlebar-uses-desktop-font ຖືກຕັ້ງເປັນ true."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:200
msgid "Number of workspaces"
msgstr "ຈຳນວນພື້ນທີ່ເຮັດວຽກ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:201
msgid ""
"Number of workspaces. Must be more than zero, and has a fixed maximum to "
"prevent making the desktop unusable by accidentally asking for too many "
"workspaces."
msgstr "ຈຳນວນພື້ນທີ່ເຮັດວຽກ. ຕ້ອງຫຼາຍກວ່າສູນ, ແລະ ມີຈຳນວນສູງສຸດທີ່ຄົງທີ່ເພື່ອປ້ອງກັນບໍ່ໃຫ້ໜ້າຈໍໃຊ້ງານບໍ່ໄດ້ໂດຍການຮ້ອງຂໍພື້ນທີ່ເຮັດວຽກຫຼາຍເກີນໄປໂດຍບັງເອີນ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:209
msgid "System Bell is Audible"
msgstr "ສຽງກະດິ່ງລະບົບສາມາດໄດ້ຍິນ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:210
msgid ""
"Determines whether applications or the system can generate audible “beeps”; "
"may be used in conjunction with “visual bell” to allow silent “beeps”."
msgstr "ກຳນົດວ່າແອັບພລິເຄຊັນ ຫຼື ລະບົບສາມາດສ້າງ “ສຽງບີບ” ທີ່ໄດ້ຍິນໄດ້ບໍ່; ອາດຈະຖືກໃຊ້ຮ່ວມກັບ “ກະດິ່ງພາບ” ເພື່ອອະນຸຍາດ “ສຽງບີບ” ແບບງຽບ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:218
msgid "Enable Visual Bell"
msgstr "ເປີດໃຊ້ກະດິ່ງພາບ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:219
msgid ""
"Turns on a visual indication when an application or the system issues a "
"“bell” or “beep”; useful for the hard-of-hearing and for use in noisy "
"environments."
msgstr "ເປີດການສະແດງຜົນທາງສາຍຕາເມື່ອແອັບພລິເຄຊັນ ຫຼື ລະບົບອອກ “ສຽງກະດິ່ງ” ຫຼື “ສຽງບີບ”; ມີປະໂຫຍດສຳລັບຜູ້ທີ່ມີບັນຫາການໄດ້ຍິນ ແລະ ສຳລັບໃຊ້ໃນສະພາບແວດລ້ອມທີ່ມີສຽງດັງ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:228
msgid "Visual Bell Type"
msgstr "ປະເພດກະດິ່ງພາບ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:229
msgid ""
"Tells the WM how to implement the visual indication that the system bell or "
"another application “bell” indicator has been rung. Currently there are two "
"valid values, “fullscreen-flash”, which causes a fullscreen white-black "
"flash, and “frame-flash” which causes the titlebar of the application which "
"sent the bell signal to flash. If the application which sent the bell is "
"unknown (as is usually the case for the default “system beep”), the "
"currently focused window’s titlebar is flashed."
msgstr "ບອກ WM ວິທີການປະຕິບັດການສະແດງຜົນທາງສາຍຕາວ່າສຽງກະດິ່ງລະບົບ ຫຼື ຕົວຊີ້ບອກ “ກະດິ່ງ” ຂອງແອັບພລິເຄຊັນອື່ນໄດ້ດັງຂຶ້ນ. ປັດຈຸບັນມີສອງຄ່າທີ່ຖືກຕ້ອງ, “fullscreen-flash”, ເຊິ່ງເຮັດໃຫ້ເກີດແສງກະພິບສີຂາວ-ດຳເຕັມໜ້າຈໍ, ແລະ “frame-flash” ເຊິ່ງເຮັດໃຫ້ແຖບຫົວຂໍ້ຂອງແອັບພລິເຄຊັນທີ່ສົ່ງສັນຍານກະດິ່ງກະພິບ. ຖ້າແອັບພລິເຄຊັນທີ່ສົ່ງກະດິ່ງບໍ່ເປັນທີ່ຮູ້ຈັກ (ເຊິ່ງມັກຈະເປັນກໍລະນີຂອງ “ສຽງບີບລະບົບ” ເລີ່ມຕົ້ນ), ແຖບຫົວຂໍ້ຂອງໜ້າຕ່າງທີ່ກຳລັງໂຟກັສຈະກະພິບ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:250
msgid "Disable misfeatures that are required by old or broken applications"
msgstr "ປິດຄຸນສົມບັດທີ່ຜິດພາດທີ່ຕ້ອງການໂດຍແອັບພລິເຄຊັນເກົ່າ ຫຼື ເສຍຫາຍ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:253
msgid ""
"Some applications disregard specifications in ways that result in window "
"manager misfeatures. This option puts the WM in a rigorously correct mode, "
"which gives a more consistent user interface, provided one does not need to "
"run any misbehaving applications."
msgstr "ບາງແອັບພລິເຄຊັນບໍ່ສົນໃຈຂໍ້ກຳນົດໃນທາງທີ່ເຮັດໃຫ້ເກີດຄຸນສົມບັດທີ່ຜິດພາດຂອງໂຕຈັດການໜ້າຕ່າງ. ຕົວເລືອກນີ້ເຮັດໃຫ້ WM ເຂົ້າສູ່ໂໝດທີ່ຖືກຕ້ອງຢ່າງເຂັ້ມງວດ, ເຊິ່ງໃຫ້ສ່ວນຕິດຕໍ່ຜູ້ໃຊ້ທີ່ສະໝ່ຳສະເໝີກວ່າ, ຖ້າບໍ່ຈຳເປັນຕ້ອງເປີດແອັບພລິເຄຊັນທີ່ເຮັດວຽກຜິດປົກກະຕິ."

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:263
msgid "The names of the workspaces"
msgstr "ຊື່ຂອງພື້ນທີ່ເຮັດວຽກ"

#: schemas/org.gnome.desktop.wm.preferences.gschema.xml.in:264
msgid ""
"Defines the names that should be assigned to workspaces. If the list is too "
"long for the current number of workspaces, names in excess will be ignored. "
"If the list is too short, or includes empty names, missing values will be "
"replaced with the default (“Workspace N”)."
msgstr "ກຳນົດຊື່ທີ່ຄວນຈະຖືກມອບໝາຍໃຫ້ກັບພື້ນທີ່ເຮັດວຽກ. ຖ້າລາຍຊື່ຍາວເກີນໄປສຳລັບຈຳນວນພື້ນທີ່ເຮັດວຽກປັດຈຸບັນ, ຊື່ທີ່ເກີນຈະຖືກບໍ່ສົນໃຈ. ຖ້າລາຍຊື່ສັ້ນເກີນໄປ, ຫຼື ມີຊື່ຫວ່າງ, ຄ່າທີ່ຂາດຫາຍໄປຈະຖືກແທນທີ່ດ້ວຍຄ່າເລີ່ມຕົ້ນ (“ພື້ນທີ່ເຮັດວຽກ N”)."

#: schemas/org.gnome.system.locale.gschema.xml.in:6
msgid "The locale to use for dates / numbers formats"
msgstr "ທ້ອງຖິ່ນທີ່ຈະໃຊ້ສຳລັບຮູບແບບວັນທີ / ຕົວເລກ"

#: schemas/org.gnome.system.locale.gschema.xml.in:7
msgid ""
"Specify the locale to be used for displaying dates, times and numbers "
"formats."
msgstr "ລະບຸທ້ອງຖິ່ນທີ່ຈະໃຊ້ສຳລັບການສະແດງຮູບແບບວັນທີ, ເວລາ ແລະ ຕົວເລກ."

#: schemas/org.gnome.system.location.gschema.xml.in:7
msgid "Geolocation services are enabled."
msgstr "ບໍລິການລະບຸຕຳແໜ່ງພູມສາດເປີດຢູ່."

#: schemas/org.gnome.system.location.gschema.xml.in:8
msgid "If true, applications are allowed to access location information."
msgstr "ຖ້າເປັນ true, ແອັບພລິເຄຊັນຈະໄດ້ຮັບອະນຸຍາດໃຫ້ເຂົ້າເຖິງຂໍ້ມູນຕຳແໜ່ງ."

#: schemas/org.gnome.system.location.gschema.xml.in:14
msgid "The maximum accuracy level of location."
msgstr "ລະດັບຄວາມຖືກຕ້ອງສູງສຸດຂອງຕຳແໜ່ງ."

#: schemas/org.gnome.system.location.gschema.xml.in:15
msgid ""
"Configures the maximum level of location accuracy applications are allowed "
"to see. Valid options are “country”, “city”, “neighborhood”, “street”, and "
"“exact” (typically requires GPS receiver). Please keep in mind that this "
"only controls what GeoClue will allow applications to see and they can find "
"user’s location on their own using network resources (albeit with street-"
"level accuracy at best)."
msgstr "ກຳນົດລະດັບຄວາມຖືກຕ້ອງສູງສຸດຂອງຕຳແໜ່ງທີ່ແອັບພລິເຄຊັນໄດ້ຮັບອະນຸຍາດໃຫ້ເບິ່ງ. ຕົວເລືອກທີ່ຖືກຕ້ອງແມ່ນ “country”, “city”, “neighborhood”, “street”, ແລະ “exact” (ປົກກະຕິຕ້ອງການເຄື່ອງຮັບ GPS). ກະລຸນາຈື່ໄວ້ວ່ານີ້ຄວບຄຸມສະເພາະສິ່ງທີ່ GeoClue ຈະອະນຸຍາດໃຫ້ແອັບພລິເຄຊັນເຫັນ ແລະ ພວກມັນສາມາດຊອກຫາຕຳແໜ່ງຂອງຜູ້ໃຊ້ໄດ້ເອງໂດຍໃຊ້ຊັບພະຍາກອນເຄືອຂ່າຍ (ເຖິງແມ່ນວ່າຈະມີຄວາມຖືກຕ້ອງໃນລະດັບຖະໜົນທີ່ດີທີ່ສຸດ)."

#: schemas/org.gnome.system.proxy.gschema.xml.in:10
msgid "Proxy configuration mode"
msgstr "ໂໝດການຕັ້ງຄ່າພຣັອກຊີ"

#: schemas/org.gnome.system.proxy.gschema.xml.in:11
msgid ""
"Select the proxy configuration mode. Supported values are “none”, “manual”, "
"“auto”. If this is “none”, then proxies are not used. If it is “auto”, the "
"autoconfiguration URL described by the “autoconfig-url” key is used. If it "
"is “manual”, then the proxies described by “/system/proxy/http”, “/system/"
"proxy/https”, “/system/proxy/ftp” and “/system/proxy/socks” will be used. "
"Each of the 4 proxy types is enabled if its “host” key is non-empty and its "
"“port” key is non-0. If an http proxy is configured, but an https proxy is "
"not, then the http proxy is also used for https. If a SOCKS proxy is "
"configured, it is used for all protocols, except that the http, https, and "
"ftp proxy settings override it for those protocols only."
msgstr "ເລືອກໂໝດການຕັ້ງຄ່າພຣັອກຊີ. ຄ່າທີ່ຮອງຮັບແມ່ນ “none”, “manual”, “auto”. ຖ້າເປັນ “none”, ພຣັອກຊີຈະບໍ່ຖືກໃຊ້. ຖ້າເປັນ “auto”, URL ການຕັ້ງຄ່າອັດຕະໂນມັດທີ່ອະທິບາຍໂດຍຄີ “autoconfig-url” ຈະຖືກໃຊ້. ຖ້າເປັນ “manual”, ພຣັອກຊີທີ່ອະທິບາຍໂດຍ “/system/proxy/http”, “/system/proxy/https”, “/system/proxy/ftp” ແລະ “/system/proxy/socks” ຈະຖືກໃຊ້. ພຣັອກຊີທັງ 4 ປະເພດຈະຖືກເປີດໃຊ້ຖ້າຄີ “host” ຂອງມັນບໍ່ວ່າງ ແລະ ຄີ “port” ຂອງມັນບໍ່ແມ່ນ 0. ຖ້າຕັ້ງຄ່າພຣັອກຊີ http, ແຕ່ບໍ່ມີພຣັອກຊີ https, ພຣັອກຊີ http ກໍ່ຈະຖືກໃຊ້ສຳລັບ https ເຊັ່ນກັນ. ຖ້າຕັ້ງຄ່າພຣັອກຊີ SOCKS, ມັນຈະຖືກໃຊ້ສຳລັບທຸກໂປຣໂຕຄອລ, ຍົກເວັ້ນວ່າການຕັ້ງຄ່າພຣັອກຊີ http, https, ແລະ ftp ຈະຖືກໃຊ້ແທນສຳລັບໂປຣໂຕຄອລເຫຼົ່ານັ້ນເທົ່ານັ້ນ."

#: schemas/org.gnome.system.proxy.gschema.xml.in:36
msgid "Automatic proxy configuration URL"
msgstr "URL ການຕັ້ງຄ່າພຣັອກຊີອັດຕະໂນມັດ"

#: schemas/org.gnome.system.proxy.gschema.xml.in:37
msgid ""
"URL that provides proxy configuration values. When mode is “auto”, this URL "
"is used to look up proxy information for all protocols."
msgstr "URL ທີ່ໃຫ້ຄ່າການຕັ້ງຄ່າພຣັອກຊີ. ເມື່ອໂໝດເປັນ “auto”, URL ນີ້ຈະຖືກໃຊ້ເພື່ອຄົ້ນຫາຂໍ້ມູນພຣັອກຊີສຳລັບທຸກໂປຣໂຕຄອລ."

#: schemas/org.gnome.system.proxy.gschema.xml.in:45
msgid "Non-proxy hosts"
msgstr "ໂຮສຕ໌ທີ່ບໍ່ໃຊ້ພຣັອກຊີ"

#: schemas/org.gnome.system.proxy.gschema.xml.in:46
msgid ""
"This key contains a list of hosts which are connected to directly, rather "
"than via the proxy (if it is active). The values can be hostnames, domains "
"(using an initial wildcard like *.foo.com), IP host addresses (both IPv4 and "
"IPv6) and network addresses with a netmask (something like 192.168.0.0/24)."
msgstr "ຄີນີ້ບັນຈຸລາຍຊື່ຂອງໂຮສຕ໌ທີ່ເຊື່ອມຕໍ່ໂດຍກົງ, ແທນທີ່ຈະຜ່ານພຣັອກຊີ (ຖ້າມັນກຳລັງໃຊ້ງານຢູ່). ຄ່າສາມາດເປັນຊື່ໂຮສຕ໌, ໂດເມນ (ໂດຍໃຊ້ wildcard ເບື້ອງຕົ້ນເຊັ່ນ *.foo.com), ທີ່ຢູ່ IP ຂອງໂຮສຕ໌ (ທັງ IPv4 ແລະ IPv6) ແລະ ທີ່ຢູ່ເຄືອຂ່າຍທີ່ມີ netmask (ບາງຢ່າງເຊັ່ນ 192.168.0.0/24)."

#: schemas/org.gnome.system.proxy.gschema.xml.in:56
msgid "Use HTTP proxy for all protocols"
msgstr "ໃຊ້ພຣັອກຊີ HTTP ສຳລັບທຸກໂປຣໂຕຄອລ"

#: schemas/org.gnome.system.proxy.gschema.xml.in:57
msgid "Whether to use the HTTP proxy for all protocols or not."
msgstr "ສະແດງວ່າຈະໃຊ້ພຣັອກຊີ HTTP ສຳລັບທຸກໂປຣໂຕຄອລບໍ່."

#: schemas/org.gnome.system.proxy.gschema.xml.in:65
msgid "Unused; ignore"
msgstr "ບໍ່ໄດ້ໃຊ້; ບໍ່ສົນໃຈ"

#: schemas/org.gnome.system.proxy.gschema.xml.in:66
msgid ""
"This key is not used; HTTP proxying is enabled when the host key is non-"
"empty and the port is non-0."
msgstr "ຄີນີ້ບໍ່ໄດ້ຖືກໃຊ້; ການໃຊ້ພຣັອກຊີ HTTP ຈະຖືກເປີດໃຊ້ເມື່ອຄີ host ບໍ່ວ່າງ ແລະ port ບໍ່ແມ່ນ 0."

#: schemas/org.gnome.system.proxy.gschema.xml.in:73
msgid "HTTP proxy host name"
msgstr "ຊື່ໂຮສຕ໌ຂອງພຣັອກຊີ HTTP"

#: schemas/org.gnome.system.proxy.gschema.xml.in:74
msgid "The machine name to proxy HTTP through."
msgstr "ຊື່ເຄື່ອງທີ່ຈະໃຊ້ເປັນພຣັອກຊີ HTTP."

#: schemas/org.gnome.system.proxy.gschema.xml.in:81
msgid "HTTP proxy port"
msgstr "ພອດພຣັອກຊີ HTTP"

#: schemas/org.gnome.system.proxy.gschema.xml.in:82
msgid ""
"The port on the machine defined by “/system/proxy/http/host” that you proxy "
"through."
msgstr "ພອດເທິງເຄື່ອງທີ່ກຳນົດໂດຍ “/system/proxy/http/host” ທີ່ທ່ານໃຊ້ເປັນພຣັອກຊີ."

#: schemas/org.gnome.system.proxy.gschema.xml.in:89
msgid "Authenticate proxy server connections"
msgstr "ຢືນຢັນການເຊື່ອມຕໍ່ເຊີບເວີພຣັອກຊີ"

#: schemas/org.gnome.system.proxy.gschema.xml.in:90
msgid ""
"If true, then connections to the proxy server require authentication. The "
"username/password combo is defined by “/system/proxy/http/authentication-"
"user” and “/system/proxy/http/authentication-password”. This applies only to "
"the http proxy; when using a separate https proxy, there is currently no way "
"to specify that it should use authentication."
msgstr "ຖ້າເປັນ true, ການເຊື່ອມຕໍ່ກັບເຊີບເວີພຣັອກຊີຈະຕ້ອງການການຢືນຢັນ. ຄູ່ຊື່ຜູ້ໃຊ້/ລະຫັດຜ່ານຖືກກຳນົດໂດຍ “/system/proxy/http/authentication-user” ແລະ “/system/proxy/http/authentication-password”. ນີ້ໃຊ້ສະເພາະກັບພຣັອກຊີ http; ເມື່ອໃຊ້ພຣັອກຊີ https ແຍກຕ່າງຫາກ, ປັດຈຸບັນຍັງບໍ່ມີວິທີລະບຸວ່າຄວນໃຊ້ການຢືນຢັນ."

#: schemas/org.gnome.system.proxy.gschema.xml.in:103
msgid "HTTP proxy username"
msgstr "ຊື່ຜູ້ໃຊ້ພຣັອກຊີ HTTP"

#: schemas/org.gnome.system.proxy.gschema.xml.in:104
msgid "User name to pass as authentication when doing HTTP proxying."
msgstr "ຊື່ຜູ້ໃຊ້ທີ່ຈະສົ່ງເປັນການຢືນຢັນເມື່ອໃຊ້ພຣັອກຊີ HTTP."

#: schemas/org.gnome.system.proxy.gschema.xml.in:110
msgid "HTTP proxy password"
msgstr "ລະຫັດຜ່ານພຣັອກຊີ HTTP"

#: schemas/org.gnome.system.proxy.gschema.xml.in:111
msgid "Password to pass as authentication when doing HTTP proxying."
msgstr "ລະຫັດຜ່ານທີ່ຈະສົ່ງເປັນການຢືນຢັນເມື່ອໃຊ້ພຣັອກຊີ HTTP."

#: schemas/org.gnome.system.proxy.gschema.xml.in:119
msgid "Secure HTTP proxy host name"
msgstr "ຊື່ໂຮສຕ໌ຂອງພຣັອກຊີ HTTP ທີ່ປອດໄພ"

#: schemas/org.gnome.system.proxy.gschema.xml.in:120
msgid "The machine name to proxy secure HTTP through."
msgstr "ຊື່ເຄື່ອງທີ່ຈະໃຊ້ເປັນພຣັອກຊີ HTTP ທີ່ປອດໄພ."

#: schemas/org.gnome.system.proxy.gschema.xml.in:127
msgid "Secure HTTP proxy port"
msgstr "ພອດພຣັອກຊີ HTTP ທີ່ປອດໄພ"

#: schemas/org.gnome.system.proxy.gschema.xml.in:128
msgid ""
"The port on the machine defined by “/system/proxy/https/host” that you proxy "
"through."
msgstr "ພອດເທິງເຄື່ອງທີ່ກຳນົດໂດຍ “/system/proxy/https/host” ທີ່ທ່ານໃຊ້ເປັນພຣັອກຊີ."

#: schemas/org.gnome.system.proxy.gschema.xml.in:137
msgid "FTP proxy host name"
msgstr "ຊື່ໂຮສຕ໌ຂອງພຣັອກຊີ FTP"

#: schemas/org.gnome.system.proxy.gschema.xml.in:138
msgid "The machine name to proxy FTP through."
msgstr "ຊື່ເຄື່ອງທີ່ຈະໃຊ້ເປັນພຣັອກຊີ FTP."

#: schemas/org.gnome.system.proxy.gschema.xml.in:145
msgid "FTP proxy port"
msgstr "ພອດພຣັອກຊີ FTP"

#: schemas/org.gnome.system.proxy.gschema.xml.in:146
msgid ""
"The port on the machine defined by “/system/proxy/ftp/host” that you proxy "
"through."
msgstr "ພອດເທິງເຄື່ອງທີ່ກຳນົດໂດຍ “/system/proxy/ftp/host” ທີ່ທ່ານໃຊ້ເປັນພຣັອກຊີ."

#: schemas/org.gnome.system.proxy.gschema.xml.in:155
msgid "SOCKS proxy host name"
msgstr "ຊື່ໂຮສຕ໌ຂອງພຣັອກຊີ SOCKS"

#: schemas/org.gnome.system.proxy.gschema.xml.in:156
msgid "The machine name to use as a SOCKS proxy."
msgstr "ຊື່ເຄື່ອງທີ່ຈະໃຊ້ເປັນພຣັອກຊີ SOCKS."

#: schemas/org.gnome.system.proxy.gschema.xml.in:163
msgid "SOCKS proxy port"
msgstr "ພອດພຣັອກຊີ SOCKS"

#: schemas/org.gnome.system.proxy.gschema.xml.in:164
msgid ""
"The port on the machine defined by “/system/proxy/socks/host” that you proxy "
"through."
msgstr "ພອດເທິງເຄື່ອງທີ່ກຳນົດໂດຍ “/system/proxy/socks/host” ທີ່ທ່ານໃຊ້ເປັນພຣັອກຊີ."
